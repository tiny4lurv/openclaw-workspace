 1 tiny4lurv tiny4lurv 3248866 Apr  1 16:33 /mnt/c/Users/Tiny4Lurv/Downloads/Updated_ Outsource Sales Rep.odt\n-rwxrwxrwx 1 tiny4lurv tiny4lurv   19187 Apr  1 16:19 /mnt/c/Users/Tiny4Lurv/Downloads/Outsource Sales Rep Guide.md\n-rwxrwxrwx 1 tiny4lurv tiny4lurv   21220 Apr  1 16:19 /mnt/c/Users/Tiny4Lurv/Downloads/Final_ Outsource Sales Rep Guide.md\n-rwxrwxrwx 1 tiny4lurv tiny4lurv   21434 Apr  1 16:19 /mnt/c/Users/Tiny4Lurv/Downloads/Updated_ Outsource Sales Rep.md\n-rwxrwxrwx 1 tiny4lurv tiny4lurv    9680 Mar 26 20:42 /mnt/c/Users/Tiny4Lurv/Downloads/Forensic Critique and Strategic Recovery_ Outsource Sales Rep.md","cwd":"/home/tiny4lurv/.openclaw/workspace"},"isError":false,"timestamp":1775054107597}}
