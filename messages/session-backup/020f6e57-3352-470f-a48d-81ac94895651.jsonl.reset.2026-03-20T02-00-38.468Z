{"type":"message","id":"40ef643e","parentId":"e6e83e59","timestamp":"2026-03-20T00:54:21.275Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"ollama_call_ccf79a6d-654a-4f81-aa8e-bee80c3af067","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\nPlaywright persistent browser for LinkedIn login\nRun this ONCE in headed mode to log in, then the profile saves.\nFuture runs will use the saved session.\n\"\"\"\n\nfrom playwright.sync_api import sync_playwright\nimport sys\nimport os\n\nPROFILE_PATH = os.path.expanduser(\"~/.openclaw/browser_profiles/linkedin_tiny\")\n\ndef main():\n    with sync_playwright() as p:\n        # Launch persistent context (saves cookies/storage)\n        browser = p.chromium.launch_persistent_context(\n            user_data_dir=PROFILE_PATH,\n            headless=False,  # VISIBLE - for login\n            viewport={\"width\": 1280, \"height\": 720},\n            slow_mo=100,  # Slight delay to feel more human\n        )\n        \n        page = browser.new_page()\n        \n        # Navigate to LinkedIn\n        print(\"Opening LinkedIn... Please log in manually.\")\n        page.goto(\"https://www.linkedin.com/login\")\n        \n        # Wait for manual login - user must complete this\n        # Check periodically if login succeeded\n        print(\"\\n=== INSTRUCTIONS ===\")\n        print(\"1. Log into LinkedIn in the browser that opened\")\n        print(\"2. Once logged in, this window will detect it\")\n        print(\"3. Press Enter here when login is complete...\")\n        print(\"====================\\n\")\n        \n        input()  # Wait for user to press Enter\n        \n        # Verify login worked\n        if \"feed\" in page.url.lower() or \"linkedin.com/in/\" in page.url:\n            print(\"✅ Logged in successfully!\")\n            print(f\"Profile saved to: {PROFILE_PATH}\")\n            print(\"\\nFuture runs will use this saved session.\")\n        else:\n            print(f\"⚠️ Current URL: {page.url}\")\n            print(\"Please verify you're logged in, then press Enter.\")\n            input()\n        \n        # Keep browser open until user closes it\n        print(\"\\nBrowser will stay open. Close it when done, or press Ctrl+C.\")\n        \n        # Just wait - user will close the browser\n        import time\n        try:\n            while browser.is_connected():\n                time.sleep(1)\n        except:\n            pass\n        \n        browser.close()\n\nif __name__ == \"__main__\":\n    main()","path":"/home/tiny4lurv/.openclaw/workspace/scripts/playwright_linkedin_login.py"}}],"stopReason":"toolUse","api":"ollama","provider":"ollama","model":"minimax-m2.5:cloud","usage":{"input":44106,"output":640,"cacheRead":0,"cacheWrite":0,"totalTokens":44746,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"timestamp":1773968061274}}
