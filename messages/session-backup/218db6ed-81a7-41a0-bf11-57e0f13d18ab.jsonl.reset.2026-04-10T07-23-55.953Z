{"type":"message","id":"9a4ba53b","parentId":"91524c00","timestamp":"2026-04-10T00:32:33.070Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"ollama_call_715913d0-b95a-43aa-990a-93ea8d92f1f9","name":"exec","arguments":{"command":"python3 << 'EOF'\nimport json\nimport os\n\ndef extract_session_summary(filepath):\n    try:\n        with open(filepath, 'r') as f:\n            lines = f.readlines()\n        \n        messages = []\n        for line in lines[-30:]:  # last 30 lines\n            try:\n                obj = json.loads(line)\n                if obj.get('role') == 'user':\n                    content = obj.get('content', '')\n                    if isinstance(content, list):\n                        content = ' '.join([c.get('text','') for c in content if c.get('type')=='text'])\n                    if content and len(content) > 20:\n                        messages.append(f\"USER: {content[:200]}\")\n                elif obj.get('role') == 'assistant':\n                    content = obj.get('content', '')\n                    if isinstance(content, list):\n                        content = ' '.join([c.get('text','') for c in content if c.get('type')=='text'])\n                    if content and len(content) > 20:\n                        messages.append(f\"ASST: {content[:200]}\")\n            except:\n                pass\n        return messages[-8:]  # last 8 messages\n    except Exception as e:\n        return [f\"Error: {e}\"]\n\nfiles = [\n    (\"/home/tiny4lurv/.openclaw/agents/main/sessions/218db6ed-81a7-41a0-bf11-57e0f13d18ab.jsonl\", \"Apr10 main session (2.6MB)\"),\n    (\"/home/tiny4lurv/.openclaw/agents/main/sessions/2974f37d-4fb2-4779-8018-c32b07bc3dc9.jsonl\", \"Apr10 subagent session\"),\n]\n\nfor fp, label in files:\n    print(f\"\\n=== {label} ===\")\n    for msg in extract_session_summary(fp):\n        print(msg[:200])\nEOF","timeout":15}}],"stopReason":"toolUse","api":"ollama","provider":"ollama","model":"minimax-m2.7:cloud","usage":{"input":70493,"output":468,"cacheRead":0,"cacheWrite":0,"totalTokens":70961,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"timestamp":1775781153061}}
