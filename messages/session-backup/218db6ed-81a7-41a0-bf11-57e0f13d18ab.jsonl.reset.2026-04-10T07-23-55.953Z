{"type":"message","id":"b7c024d5","parentId":"0ad0e19f","timestamp":"2026-04-09T21:23:32.555Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"ollama_call_5ed8677e-368f-4e67-a2fc-9c62bf321176","name":"read","arguments":{"path":"/mnt/c/Users/Tiny4Lurv/OneDrive/Documents/AntiGravity/job_board_automation/widget/script.js"}}],"stopReason":"toolUse","api":"ollama","provider":"ollama","model":"minimax-m2.7:cloud","usage":{"input":67346,"output":243,"cacheRead":0,"cacheWrite":0,"totalTokens":67589,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"timestamp":1775769812553}}
{"type":"message","id":"28ddaa80","parentId":"b7c024d5","timestamp":"2026-04-09T21:23:32.664Z","message":{"role":"toolResult","toolCallId":"ollama_call_5ed8677e-368f-4e67-a2fc-9c62bf321176","toolName":"read","content":[{"type":"text","text":"document.addEventListener('DOMContentLoaded', () => {\n    const gridContainer = document.getElementById('job-grid-container');\n    const modal = document.getElementById('job-modal');\n    const closeBtn = document.getElementById('modal-close-btn');\n\n    // Modal elements\n    const mTitle = document.getElementById('modal-title');\n    const mMeta = document.getElementById('modal-meta');\n    const mSalary = document.getElementById('modal-salary');\n    const mDesc = document.getElementById('modal-description');\n    const mReqList = document.getElementById('modal-requirements-list');\n    const mReqSection = document.getElementById('modal-requirements-section');\n    const mApplyBtn = document.getElementById('modal-apply-btn');\n\n    let allJobs = [];\n\n    // Fetch the generated JSON file\n    fetch('../jobs.json')\n        .then(response => {\n            if (!response.ok) throw new Error('Could not load jobs');\n            return response.json();\n        })\n        .then(jobs => {\n            allJobs = jobs;\n            renderJobs(jobs);\n        })\n        .catch(err => {\n            gridContainer.innerHTML = `<div class=\"loading-state\">Error loading jobs. Please try again later.</div>`;\n            console.error(err);\n        });\n\n    function renderJobs(jobs) {\n        gridContainer.innerHTML = '';\n        \n        if (jobs.length === 0) {\n            gridContainer.innerHTML = `<div class=\"loading-state\">No open positions at this time.</div>`;\n            return;\n        }\n\n        // 1. Group jobs by State\n        const jobsByState = {};\n        jobs.forEach(job => {\n            // Assume location is \"City, ST\" or similar. Grab the last part after a comma.\n            let stateName = \"Other Locations\";\n            if (job.location && job.location.includes(',')) {\n                const parts = job.location.split(',');\n                stateName = parts[parts.length - 1].trim().toUpperCase();\n            }\n            \n            if (!jobsByState[stateName]) {\n                jobsByState[stateName] = [];\n            }\n            jobsByState[stateName].push(job);\n        });\n\n        // 2. Sort states alphabetically\n        const sortedStates = Object.keys(jobsByState).sort();\n\n        // 3. Render Groups\n        sortedStates.forEach(state => {\n            const stateJobCount = jobsByState[state].length;\n            \n            // Create a full-width header for the state\n            const stateHeader = document.createElement('div');\n            stateHeader.className = 'state-header';\n            stateHeader.innerHTML = `<h3>Available Positions in ${state} (${stateJobCount})</h3><span class=\"toggle-icon\" style=\"transition: transform 0.3s ease; transform: rotate(-90deg);\">▼</span>`;\n            // Make the header span all columns\n            stateHeader.style.gridColumn = '1 / -1'; \n            stateHeader.style.color = 'var(--modal-text)';\n            stateHeader.style.borderBottom = '1px solid var(--text-secondary)';\n            stateHeader.style.paddingBottom = '10px';\n            stateHeader.style.marginTop = '20px';\n            stateHeader.style.marginBottom = '10px';\n            stateHeader.style.display = 'flex';\n            stateHeader.style.justifyContent = 'space-between';\n            stateHeader.style.alignItems = 'center';\n            stateHeader.style.cursor = 'pointer';\n            stateHeader.style.userSelect = 'none';\n            gridContainer.appendChild(stateHeader);\n\n            const stateCardElements = [];\n\n            // Render cards for this state\n            jobsByState[state].forEach(job => {\n                // Find global index for the modal click event\n                const globalIndex = allJobs.findIndex(j => j.id === job.id);\n                \n                const card = document.createElement('div');\n                card.className = 'job-card';\n                // DEFAULT TO HIDDEN\n                card.style.display = 'none';\n                \n                const salaryHtml = job.salaryShort ? `<div class=\"card-salary\">${job.salaryShort}</div>` : '';\n\n                card.innerHTML = `\n                    <div class=\"card-header-row\">\n                        <div class=\"card-title\">${job.roleTitle}</div>\n                        ${salaryHtml}\n                    </div>\n                    <div class=\"card-meta\">${job.location} &bull; ${job.contractType}</div>\n                    <div class=\"card-description\">${job.description}</div>\n                    <button class=\"card-apply-btn\">Apply Now</button>\n                `;\n\n                card.addEventListener('click', () => openModal(globalIndex));\n                stateCardElements.push(card);\n                gridContainer.appendChild(card);\n            });\n\n            // Accordion toggle logic\n            let isCollapsed = true; // DEFAULT TO TRUE\n            stateHeader.addEventListener('click', () => {\n                isCollapsed = !isCollapsed;\n                const icon = stateHeader.querySelector('.toggle-icon');\n                if (isCollapsed) {\n                    icon.style.transform = 'rotate(-90deg)';\n                    stateCardElements.forEach(card => card.style.display = 'none');\n                } else {\n                    icon.style.transform = 'rotate(0deg)';\n                    stateCardElements.forEach(card => card.style.display = 'flex');\n                }\n            });\n        });\n    }\n\n    function openModal(index) {\n        const job = allJobs[index];\n        \n        mTitle.textContent = job.roleTitle;\n        mMeta.innerHTML = `${job.location} &bull; ${job.contractType}`;\n        \n        // Prioritize the longer salary info, fallback to short, fallback to empty\n        mSalary.textContent = job.salaryOrBonusInfo || job.salaryShort || '';\n        \n        mDesc.textContent = job.description; // textContent handles newlines naturally with white-space: pre-wrap\n        \n        mApplyBtn.href = job.applyLink;\n\n        // Render Requirements\n        if (job.requirements && job.requirements.length > 0) {\n            mReqSection.style.display = 'block';\n            mReqList.innerHTML = '';\n            job.requirements.forEach(req => {\n                const li = document.createElement('li');\n                li.textContent = req;\n                mReqList.appendChild(li);\n            });\n        } else {\n            mReqSection.style.display = 'none';\n        }\n\n        modal.classList.add('active');\n        document.body.style.overflow = 'hidden'; // Prevent background scrolling\n    }\n\n    function closeModal() {\n        modal.classList.remove('active');\n        document.body.style.overflow = 'auto';\n    }\n\n    closeBtn.addEventListener('click', closeModal);\n    \n    // Close on outside click\n    modal.addEventListener('click', (e) => {\n        if (e.target === modal) {\n            closeModal();\n        }\n    });\n\n    // Close on Escape key\n    document.addEventListener('keydown', (e) => {\n        if (e.key === 'Escape') {\n            closeModal();\n        }\n    });\n});\n"}],"isError":false,"timestamp":1775769812653}}
{"type":"message","id":"9d080ea1","parentId":"28ddaa80","timestamp":"2026-04-09T21:23:38.509Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"ollama_call_f2443197-ad63-4854-beac-eb3f678d3d89","name":"read","arguments":{"path":"/mnt/c/Users/Tiny4Lurv/OneDrive/Documents/AntiGravity/job_board_automation/index.js"}}],"stopReason":"toolUse","api":"ollama","provider":"ollama","model":"minimax-m2.7:cloud","usage":{"input":69669,"output":282,"cacheRead":0,"cacheWrite":0,"totalTokens":69951,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"timestamp":1775769818507}}
{"type":"message","id":"47b9e4c9","parentId":"9d080ea1","timestamp":"2026-04-09T21:23:38.597Z","message":{"role":"toolResult","toolCallId":"ollama_call_f2443197-ad63-4854-beac-eb3f678d3d89","toolName":"read","content":[{"type":"text","text":"const { getActiveJobs } = require('./src/fetchSheetData');\nconst { loadCache, saveCache, generateJobId, generateJobSignature } = require('./src/jobCache');\nconst { processNewJobsWithGemini } = require('./src/geminiInterface');\nconst { overwriteFinalOutput } = require('./src/outputJson');\n\nconst SHEET_ID = '1Bsm2ceTy3lBq7t7JMOXOEtEBp_gUxkL0d78ZXnGKocs';\n\nasync function main() {\n  console.log('--- Starting Job Board Sync ---');\n  try {\n      // 1. Fetch active jobs from Google Sheets\n      const allActiveJobs = await getActiveJobs(SHEET_ID, ''); \n      console.log(`[Google Sheets] Found ${allActiveJobs.length} active roles.`);\n\n      // 2. Identify new, updated, and existing jobs\n      const cache = loadCache();\n      const newOrUpdatedJobs = [];\n      const finalActiveJobsToPublish = [];\n      const activeJobIds = new Set();\n      \n      for (const job of allActiveJobs) {\n          const id = generateJobId(job);\n          const signature = generateJobSignature(job);\n          \n          job.id = id;\n          job.signature = signature;\n          activeJobIds.add(id);\n\n          // Check if this exact job signature is already processed and cached\n          if (cache[id] && cache[id].signature === signature && cache[id].finalJson) {\n              // It's unchanged. Keep the existing generated JSON.\n              finalActiveJobsToPublish.push(cache[id].finalJson);\n          } else {\n              // It's new or modified. Send to Gemini.\n              newOrUpdatedJobs.push(job);\n          }\n      }\n      \n      // Cleanup old cache entries that are no longer on the sheet\n      for (const cachedId of Object.keys(cache)) {\n          if (!activeJobIds.has(cachedId)) {\n              delete cache[cachedId];\n          }\n      }\n\n      if (newOrUpdatedJobs.length === 0) {\n          console.log(`[Sync] No changes detected. All ${finalActiveJobsToPublish.length} jobs are up to date.`);\n      } else {\n          console.log(`[Sync] Found ${newOrUpdatedJobs.length} new or modified jobs to process with Gemini.`);\n          // 3. Process new/updated jobs with Gemini\n          const processedJobs = await processNewJobsWithGemini(newOrUpdatedJobs);\n          \n          for (const pJob of processedJobs) {\n              if (!pJob) continue; // Skip if Gemini errored\n              finalActiveJobsToPublish.push(pJob);\n              \n              const originalJob = newOrUpdatedJobs.find(j => j.id === pJob.id);\n              if (originalJob) {\n                  cache[pJob.id] = {\n                      signature: originalJob.signature,\n                      addedAt: new Date().toISOString(),\n                      finalJson: pJob\n                  };\n              }\n          }\n          saveCache(cache);\n      }\n      \n      // 4. Overwrite jobs.json so it EXACTLY matches the Google Sheet (removes inactive jobs)\n      overwriteFinalOutput(finalActiveJobsToPublish);\n      console.log(`\\n--- Success: Job Board is fully synced! ---`);\n\n  } catch (err) {\n      console.error('Error in execution:', err);\n  }\n}\n\nmain();\n"}],"isError":false,"timestamp":1775769818586}}
