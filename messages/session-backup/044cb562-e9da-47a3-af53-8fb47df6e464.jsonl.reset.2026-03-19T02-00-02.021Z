3zhJ-y6BjqMifUVa9n6jb6XjsFqJoieka9uw==\",\"summary\":[{\"type\":\"summary_text\",\"text\":\"**Suggesting WSL-based script fix**\"}]}"},{"type":"toolCall","id":"call_rrVw3TOAqDuEpKtVpv73SBg6|fc_09c1eed3dfa3a32d0169ba713b2ebc819bba9af7112227c516","name":"write","arguments":{"path":"/mnt/c/Users/Tiny4Lurv/openclaw-model-preflight.ps1","content":"param(\n  [string]$OllamaModel = \"ollama/qwen3:4b-instruct\",\n  [string]$FallbackModel = \"openai-codex/gpt-5.3-codex\",\n  [string]$OllamaUrl = \"http://127.0.0.1:11434/api/tags\",\n  [int]$TimeoutSec = 2,\n  [string]$WslDistro = \"Ubuntu\"\n)\n\n$ErrorActionPreference = \"Stop\"\n\nfunction Set-Model([string]$model) {\n  Write-Host \"[preflight] setting OpenClaw model -> $model\"\n\n  # Try native Windows openclaw first\n  $native = Get-Command openclaw -ErrorAction SilentlyContinue\n  if ($native) {\n    openclaw models set $model | Out-Host\n    return\n  }\n\n  # Fallback: run openclaw inside WSL distro\n  wsl -d $WslDistro bash -lc \"openclaw models set '$model'\" | Out-Host\n}\n\ntry {\n  $resp = Invoke-WebRequest -UseBasicParsing -Uri $OllamaUrl -TimeoutSec $TimeoutSec\n  if ($resp.StatusCode -eq 200) {\n    Set-Model $OllamaModel\n    Write-Host \"[preflight] Ollama reachable. Local-first mode active.\"\n    exit 0\n  }\n\n  Set-Model $FallbackModel\n  Write-Host \"[preflight] Ollama probe non-200. Fallback active.\"\n  exit 0\n}\ncatch {\n  Set-Model $FallbackModel\n  Write-Host \"[preflight] Ollama unreachable. Fallback active.\"\n  exit 0\n}\n"},"partialJson":"{\"path\":\"/mnt/c/Users/Tiny4Lurv/openclaw-model-preflight.ps1\",\"content\":\"param(\\n  [string]$OllamaModel = \\\"ollama/qwen3:4b-instruct\\\",\\n  [string]$FallbackModel = \\\"openai-codex/gpt-5.3-codex\\\",\\n  [string]$OllamaUrl = \\\"http://127.0.0.1:11434/api/tags\\\",\\n  [int]$TimeoutSec = 2,\\n  [string]$WslDistro = \\\"Ubuntu\\\"\\n)\\n\\n$ErrorActionPreference = \\\"Stop\\\"\\n\\nfunction Set-Model([string]$model) {\\n  Write-Host \\\"[preflight] setting OpenClaw model -> $model\\\"\\n\\n  # Try native Windows openclaw first\\n  $native = Get-Command openclaw -ErrorAction SilentlyContinue\\n  if ($native) {\\n    openclaw models set $model | Out-Host\\n    return\\n  }\\n\\n  # Fallback: run openclaw inside WSL distro\\n  wsl -d $WslDistro bash -lc \\\"openclaw models set '$model'\\\" | Out-Host\\n}\\n\\ntry {\\n  $resp = Invoke-WebRequest -UseBasicParsing -Uri $OllamaUrl -TimeoutSec $TimeoutSec\\n  if ($resp.StatusCode -eq 200) {\\n    Set-Model $OllamaModel\\n    Write-Host \\\"[preflight] Ollama reachable. Local-first mode active.\\\"\\n    exit 0\\n  }\\n\\n  Set-Model $FallbackModel\\n  Write-Host \\\"[preflight] Ollama probe non-200. Fallback active.\\\"\\n  exit 0\\n}\\ncatch {\\n  Set-Model $FallbackModel\\n  Write-Host \\\"[preflight] Ollama unreachable. Fallback active.\\\"\\n  exit 0\\n}\\n\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.3-codex","usage":{"input":70246,"output":597,"cacheRead":0,"cacheWrite":0,"totalTokens":70843,"cost":{"input":0.1229305,"output":0.008357999999999999,"cacheRead":0,"cacheWrite":0,"total":0.1312885}},"stopReason":"toolUse","timestamp":1773826354769}}
