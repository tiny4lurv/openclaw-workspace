XX8bMLRpuN3aDBE|fc_09c1eed3dfa3a32d0169ba6d91a454819ba6b8a839e6105bd8","name":"write","arguments":{"path":"/home/tiny4lurv/.openclaw/workspace/scripts/openclaw-model-preflight.ps1","content":"param(\n  [string]$OllamaModel = \"ollama/qwen3:4b-instruct\",\n  [string]$FallbackModel = \"openai-codex/gpt-5.3-codex\",\n  [string]$OllamaUrl = \"http://127.0.0.1:11434/api/tags\",\n  [int]$TimeoutSec = 2\n)\n\n$ErrorActionPreference = \"Stop\"\n\nfunction Set-Model([string]$model) {\n  Write-Host \"[preflight] setting OpenClaw model -> $model\"\n  openclaw models set $model | Out-Host\n}\n\ntry {\n  $resp = Invoke-WebRequest -UseBasicParsing -Uri $OllamaUrl -TimeoutSec $TimeoutSec\n  if ($resp.StatusCode -eq 200) {\n    Set-Model $OllamaModel\n    Write-Host \"[preflight] Ollama reachable. Local-first mode active.\"\n    exit 0\n  }\n\n  Set-Model $FallbackModel\n  Write-Host \"[preflight] Ollama probe non-200. Fallback active.\"\n  exit 0\n}\ncatch {\n  Set-Model $FallbackModel\n  Write-Host \"[preflight] Ollama unreachable. Fallback active.\"\n  exit 0\n}\n"},"partialJson":"{\"path\":\"/home/tiny4lurv/.openclaw/workspace/scripts/openclaw-model-preflight.ps1\",\"content\":\"param(\\n  [string]$OllamaModel = \\\"ollama/qwen3:4b-instruct\\\",\\n  [string]$FallbackModel = \\\"openai-codex/gpt-5.3-codex\\\",\\n  [string]$OllamaUrl = \\\"http://127.0.0.1:11434/api/tags\\\",\\n  [int]$TimeoutSec = 2\\n)\\n\\n$ErrorActionPreference = \\\"Stop\\\"\\n\\nfunction Set-Model([string]$model) {\\n  Write-Host \\\"[preflight] setting OpenClaw model -> $model\\\"\\n  openclaw models set $model | Out-Host\\n}\\n\\ntry {\\n  $resp = Invoke-WebRequest -UseBasicParsing -Uri $OllamaUrl -TimeoutSec $TimeoutSec\\n  if ($resp.StatusCode -eq 200) {\\n    Set-Model $OllamaModel\\n    Write-Host \\\"[preflight] Ollama reachable. Local-first mode active.\\\"\\n    exit 0\\n  }\\n\\n  Set-Model $FallbackModel\\n  Write-Host \\\"[preflight] Ollama probe non-200. Fallback active.\\\"\\n  exit 0\\n}\\ncatch {\\n  Set-Model $FallbackModel\\n  Write-Host \\\"[preflight] Ollama unreachable. Fallback active.\\\"\\n  exit 0\\n}\\n\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.3-codex","usage":{"input":1815,"output":444,"cacheRead":65280,"cacheWrite":0,"totalTokens":67539,"cost":{"input":0.00317625,"output":0.006216,"cacheRead":0.011424,"cacheWrite":0,"total":0.02081625}},"stopReason":"toolUse","timestamp":1773825415412}}
