19bb7f87877066fa56e","name":"write","arguments":{"path":"/mnt/c/Users/Tiny4Lurv/openclaw-model-preflight.ps1","content":"param(\n  [string]$OllamaModel = \"ollama/qwen3:4b-instruct\",\n  [string]$FallbackModel = \"openai-codex/gpt-5.3-codex\",\n  [string]$OllamaUrl = \"http://127.0.0.1:11434/api/tags\",\n  [int]$TimeoutSec = 2\n)\n\n$ErrorActionPreference = \"Stop\"\n\nfunction Set-Model([string]$model) {\n  Write-Host \"[preflight] setting OpenClaw model -> $model\"\n  openclaw models set $model | Out-Host\n}\n\ntry {\n  $resp = Invoke-WebRequest -UseBasicParsing -Uri $OllamaUrl -TimeoutSec $TimeoutSec\n  if ($resp.StatusCode -eq 200) {\n    Set-Model $OllamaModel\n    Write-Host \"[preflight] Ollama reachable. Local-first mode active.\"\n    exit 0\n  }\n\n  Set-Model $FallbackModel\n  Write-Host \"[preflight] Ollama probe non-200. Fallback active.\"\n  exit 0\n}\ncatch {\n  Set-Model $FallbackModel\n  Write-Host \"[preflight] Ollama unreachable. Fallback active.\"\n  exit 0\n}\n"},"partialJson":"{\"path\":\"/mnt/c/Users/Tiny4Lurv/openclaw-model-preflight.ps1\",\"content\":\"param(\\n  [string]$OllamaModel = \\\"ollama/qwen3:4b-instruct\\\",\\n  [string]$FallbackModel = \\\"openai-codex/gpt-5.3-codex\\\",\\n  [string]$OllamaUrl = \\\"http://127.0.0.1:11434/api/tags\\\",\\n  [int]$TimeoutSec = 2\\n)\\n\\n$ErrorActionPreference = \\\"Stop\\\"\\n\\nfunction Set-Model([string]$model) {\\n  Write-Host \\\"[preflight] setting OpenClaw model -> $model\\\"\\n  openclaw models set $model | Out-Host\\n}\\n\\ntry {\\n  $resp = Invoke-WebRequest -UseBasicParsing -Uri $OllamaUrl -TimeoutSec $TimeoutSec\\n  if ($resp.StatusCode -eq 200) {\\n    Set-Model $OllamaModel\\n    Write-Host \\\"[preflight] Ollama reachable. Local-first mode active.\\\"\\n    exit 0\\n  }\\n\\n  Set-Model $FallbackModel\\n  Write-Host \\\"[preflight] Ollama probe non-200. Fallback active.\\\"\\n  exit 0\\n}\\ncatch {\\n  Set-Model $FallbackModel\\n  Write-Host \\\"[preflight] Ollama unreachable. Fallback active.\\\"\\n  exit 0\\n}\\n\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.3-codex","usage":{"input":68773,"output":456,"cacheRead":0,"cacheWrite":0,"totalTokens":69229,"cost":{"input":0.12035275,"output":0.006384,"cacheRead":0,"cacheWrite":0,"total":0.12673674999999998}},"stopReason":"toolUse","timestamp":1773826083510}}
