{"type":"message","id":"6f21cef1","parentId":"4c709b95","timestamp":"2026-03-17T15:18:07.473Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_8ERyS1gbOY3LJVMcKc8Y8NQE|fc_0278252ab7917d830169b970a2798c8191be321d37818ea4e7","name":"write","arguments":{"path":"/home/tiny4lurv/.openclaw/workspace/rag/index/query_rag.py","content":"#!/usr/bin/env python3\nfrom __future__ import annotations\nfrom pathlib import Path\nimport argparse\nimport json\nimport math\nimport re\nfrom collections import Counter, defaultdict\n\nROOT = Path('/home/tiny4lurv/.openclaw/workspace')\nINDEX = ROOT / 'rag' / 'index' / 'bm25_index.json'\nTOKEN_RE = re.compile(r\"[a-zA-Z][a-zA-Z0-9\\-]{1,}\")\n\n\ndef tokenize(text: str):\n    return [t.lower() for t in TOKEN_RE.findall(text)]\n\n\ndef score_query(idx: dict, query: str, k: int = 5):\n    q_terms = tokenize(query)\n    if not q_terms:\n        return []\n\n    df = idx['df']\n    postings = idx['postings']\n    docs = idx['docs']\n    meta = idx['meta']\n    N = meta['num_docs']\n    avgdl = meta['avgdl']\n    k1 = meta.get('k1', 1.5)\n    b = meta.get('b', 0.75)\n\n    scores = defaultdict(float)\n\n    for term in q_terms:\n        plist = postings.get(term)\n        if not plist:\n            continue\n        n_qi = df.get(term, 0)\n        # BM25 idf variant\n        idf = math.log(1 + (N - n_qi + 0.5) / (n_qi + 0.5))\n        for dix, tf in plist:\n            dl = docs[dix]['len']\n            denom = tf + k1 * (1 - b + b * (dl / avgdl))\n            s = idf * ((tf * (k1 + 1)) / denom)\n            scores[dix] += s\n\n    ranked = sorted(scores.items(), key=lambda x: x[1], reverse=True)[:k]\n    out = []\n    for dix, s in ranked:\n        d = docs[dix]\n        snippet = d['text'][:400].replace('\\n', ' ')\n        out.append({\n            'score': round(s, 4),\n            'id': d['id'],\n            'path': d['path'],\n            'source_type': d['source_type'],\n            'chunk_index': d['chunk_index'],\n            'snippet': snippet,\n        })\n    return out\n\n\ndef main():\n    ap = argparse.ArgumentParser()\n    ap.add_argument('query', type=str)\n    ap.add_argument('-k', type=int, default=5)\n    args = ap.parse_args()\n\n    idx = json.loads(INDEX.read_text(encoding='utf-8'))\n    res = score_query(idx, args.query, args.k)\n    print(json.dumps({'query': args.query, 'results': res}, ensure_ascii=False, indent=2))\n\n\nif __name__ == '__main__':\n    main()\n"},"partialJson":"{\"path\":\"/home/tiny4lurv/.openclaw/workspace/rag/index/query_rag.py\",\"content\":\"#!/usr/bin/env python3\\nfrom __future__ import annotations\\nfrom pathlib import Path\\nimport argparse\\nimport json\\nimport math\\nimport re\\nfrom collections import Counter, defaultdict\\n\\nROOT = Path('/home/tiny4lurv/.openclaw/workspace')\\nINDEX = ROOT / 'rag' / 'index' / 'bm25_index.json'\\nTOKEN_RE = re.compile(r\\\"[a-zA-Z][a-zA-Z0-9\\\\-]{1,}\\\")\\n\\n\\ndef tokenize(text: str):\\n    return [t.lower() for t in TOKEN_RE.findall(text)]\\n\\n\\ndef score_query(idx: dict, query: str, k: int = 5):\\n    q_terms = tokenize(query)\\n    if not q_terms:\\n        return []\\n\\n    df = idx['df']\\n    postings = idx['postings']\\n    docs = idx['docs']\\n    meta = idx['meta']\\n    N = meta['num_docs']\\n    avgdl = meta['avgdl']\\n    k1 = meta.get('k1', 1.5)\\n    b = meta.get('b', 0.75)\\n\\n    scores = defaultdict(float)\\n\\n    for term in q_terms:\\n        plist = postings.get(term)\\n        if not plist:\\n            continue\\n        n_qi = df.get(term, 0)\\n        # BM25 idf variant\\n        idf = math.log(1 + (N - n_qi + 0.5) / (n_qi + 0.5))\\n        for dix, tf in plist:\\n            dl = docs[dix]['len']\\n            denom = tf + k1 * (1 - b + b * (dl / avgdl))\\n            s = idf * ((tf * (k1 + 1)) / denom)\\n            scores[dix] += s\\n\\n    ranked = sorted(scores.items(), key=lambda x: x[1], reverse=True)[:k]\\n    out = []\\n    for dix, s in ranked:\\n        d = docs[dix]\\n        snippet = d['text'][:400].replace('\\\\n', ' ')\\n        out.append({\\n            'score': round(s, 4),\\n            'id': d['id'],\\n            'path': d['path'],\\n            'source_type': d['source_type'],\\n            'chunk_index': d['chunk_index'],\\n            'snippet': snippet,\\n        })\\n    return out\\n\\n\\ndef main():\\n    ap = argparse.ArgumentParser()\\n    ap.add_argument('query', type=str)\\n    ap.add_argument('-k', type=int, default=5)\\n    args = ap.parse_args()\\n\\n    idx = json.loads(INDEX.read_text(encoding='utf-8'))\\n    res = score_query(idx, args.query, args.k)\\n    print(json.dumps({'query': args.query, 'results': res}, ensure_ascii=False, indent=2))\\n\\n\\nif __name__ == '__main__':\\n    main()\\n\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.3-codex","usage":{"input":130,"output":727,"cacheRead":96768,"cacheWrite":0,"totalTokens":97625,"cost":{"input":0.0002275,"output":0.010178,"cacheRead":0.0169344,"cacheWrite":0,"total":0.0273399}},"stopReason":"toolUse","timestamp":1773760663750}}
