rguments":{"file_path":"rag/index/query_rag.py","content":"#!/usr/bin/env python3\nfrom __future__ import annotations\nfrom pathlib import Path\nimport argparse\nimport hashlib\nimport json\nimport math\nimport re\nfrom collections import Counter, defaultdict\n\nROOT = Path('/home/tiny4lurv/.openclaw/workspace')\nBM25_INDEX = ROOT / 'rag' / 'index' / 'bm25_index.json'\nVECTOR_INDEX = ROOT / 'rag' / 'index' / 'vector_index.json'\nTOKEN_RE = re.compile(r\"[a-zA-Z][a-zA-Z0-9\\-]{1,}\")\n\nFALLBACK_DIMS = 768\nNGRAM_MIN = 3\nNGRAM_MAX = 5\n\n_ST_MODEL_CACHE = {}\n\n\ndef tokenize(text: str):\n    return [t.lower() for t in TOKEN_RE.findall(text)]\n\n\ndef hash_feature(s: str, dims: int):\n    h = hashlib.sha1(s.encode('utf-8')).digest()\n    idx = int.from_bytes(h[:4], 'big') % dims\n    sign = 1.0 if (h[4] & 1) == 0 else -1.0\n    return idx, sign\n\n\ndef char_ngrams(token: str):\n    t = f\"^{token}$\"\n    n = len(t)\n    for k in range(NGRAM_MIN, NGRAM_MAX + 1):\n        if n < k:\n            continue\n        for i in range(0, n - k + 1):\n            yield t[i:i + k]\n\n\ndef l2_normalize(v):\n    norm = math.sqrt(sum(x * x for x in v))\n    if norm == 0:\n        return v\n    return [x / norm for x in v]\n\n\ndef fallback_query_vector(query: str, dims: int):\n    toks = tokenize(query)\n    tf = Counter(toks)\n    vec = [0.0] * dims\n    for tok, freq in tf.items():\n        w = 1.0 + math.log(freq)\n        idx, sign = hash_feature(f\"tok::{tok}\", dims)\n        vec[idx] += sign * w\n        for ng in char_ngrams(tok):\n            ng_idx, ng_sign = hash_feature(f\"ng::{ng}\", dims)\n            vec[ng_idx] += ng_sign * (w * 0.25)\n    return l2_normalize(vec)\n\n\ndef dot(a, b):\n    return sum(x * y for x, y in zip(a, b))\n\n\ndef normalize_scores(d):\n    if not d:\n        return {}\n    vals = list(d.values())\n    lo, hi = min(vals), max(vals)\n    if hi <= lo:\n        return {k: 1.0 for k in d}\n    return {k: (v - lo) / (hi - lo) for k, v in d.items()}\n\n\ndef score_bm25(idx: dict, query: str, source: str = 'both'):\n    q_terms = tokenize(query)\n    if not q_terms:\n        return {}\n\n    df = idx['df']\n    postings = idx['postings']\n    docs = idx['docs']\n    meta = idx['meta']\n    N = meta['num_docs']\n    avgdl = meta['avgdl']\n    k1 = meta.get('k1', 1.5)\n    b = meta.get('b', 0.75)\n\n    scores = defaultdict(float)\n\n    for term in q_terms:\n        plist = postings.get(term)\n        if not plist:\n            continue\n        n_qi = df.get(term, 0)\n        idf = math.log(1 + (N - n_qi + 0.5) / (n_qi + 0.5))\n        for dix, tf in plist:\n            d = docs[dix]\n            if source != 'both' and d['source_type'] != source:\n                continue\n            dl = d['len']\n            denom = tf + k1 * (1 - b + b * (dl / avgdl))\n            s = idf * ((tf * (k1 + 1)) / denom)\n            scores[d['id']] += s\n\n    return dict(scores)\n\n\ndef encode_query_transformer(query: str, model_name: str):\n    try:\n        from sentence_transformers import SentenceTransformer\n    except Exception:\n        return None\n\n    model = _ST_MODEL_CACHE.get(model_name)\n    if model is None:\n        model = SentenceTransformer(model_name)\n        _ST_MODEL_CACHE[model_name] = model\n\n    vec = model.encode([query], normalize_embeddings=True, show_progress_bar=False)[0]\n    return list(map(float, vec))\n\n\ndef score_vector(vidx: dict, query: str, source: str = 'both'):\n    docs = vidx['docs']\n    vectors = vidx['vectors']\n    meta = vidx.get('meta', {})\n    backend = meta.get('backend', '')\n    dims = int(meta.get('dims', FALLBACK_DIMS))\n    model_name = meta.get('model')\n\n    qv = None\n    if backend == 'sentence_transformers' and model_name:\n        qv = encode_query_transformer(query, model_name)\n\n    if qv is None:\n        qv = fallback_query_vector(query, dims)\n\n    scores = {}\n    for d, dv in zip(docs, vectors):\n        if source != 'both' and d['source_type'] != source:\n            continue\n        scores[d['id']] = dot(qv, dv)\n    return scores\n\n\ndef rerank_with_cross_encoder(query: str, candidates: list[tuple[str, float]], doc_by_id: dict, model_name: str, topn: int):\n    try:\n        from sentence_transformers import CrossEncoder\n    except Exception:\n        return candidates\n\n    head = candidates[:topn]\n    if not head:\n        return candidates\n\n    model = CrossEncoder(model_name)\n    pairs = [(query, doc_by_id[doc_id]['text']) for doc_id, _ in head]\n    scores = model.predict(pairs)\n    reranked_head = sorted(\n        [(doc_id, float(score)) for (doc_id, _), score in zip(head, scores)],\n        key=lambda x: x[1],\n        reverse=True,\n    )\n    tail = candidates[topn:]\n    return reranked_head + tail\n\n\ndef render_results(query: str, doc_by_id: dict, ranked_scores, k: int):\n    out = []\n    for doc_id, s in ranked_scores[:k]:\n        d = doc_by_id[doc_id]\n        snippet = d['text'][:400].replace('\\n', ' ')\n        out.append({\n            'score': round(s, 4),\n            'id': d['id'],\n            'path': d['path'],\n            'source_type': d['source_type'],\n            'chunk_index': d['chunk_index'],\n            'snippet': snippet,\n        })\n    return {'query': query, 'results': out}\n\n\ndef main():\n    ap = argparse.ArgumentParser()\n    ap.add_argument('query', type=str)\n    ap.add_argument('-k', type=int, default=5)\n    ap.add_argument('--source', choices=['both', 'website', 'docs'], default='both')\n    ap.add_argument('--mode', choices=['bm25', 'vector', 'hybrid'], default='hybrid')\n    ap.add_argument('--alpha', type=float, default=0.6, help='BM25 weight in hybrid mode (0..1)')\n    ap.add_argument('--rerank', action='store_true', help='Apply cross-encoder reranking to fused top candidates')\n    ap.add_argument('--rerank-model', default='BAAI/bge-reranker-base')\n    ap.add_argument('--rerank-topn', type=int, default=20)\n    args = ap.parse_args()\n\n    bm25_idx = json.loads(BM25_INDEX.read_text(encoding='utf-8'))\n    bm25_docs = bm25_idx['docs']\n    bm25_doc_by_id = {d['id']: d for d in bm25_docs}\n\n    if args.mode == 'bm25':\n        bm25_scores = score_bm25(bm25_idx, args.query, args.source)\n        ranked = sorted(bm25_scores.items(), key=lambda x: x[1], reverse=True)\n        print(json.dumps(render_results(args.query, bm25_doc_by_id, ranked, args.k), ensure_ascii=False, indent=2))\n        return\n\n    if not VECTOR_INDEX.exists():\n        raise SystemExit('vector_index.json not found. Run build_vector_index.py first.')\n    vidx = json.loads(VECTOR_INDEX.read_text(encoding='utf-8'))\n    vec_docs = vidx['docs']\n    vec_doc_by_id = {d['id']: d for d in vec_docs}\n\n    if args.mode == 'vector':\n        vec_scores = score_vector(vidx, args.query, args.source)\n        ranked = sorted(vec_scores.items(), key=lambda x: x[1], reverse=True)\n        if args.rerank:\n            ranked = rerank_with_cross_encoder(args.query, ranked, vec_doc_by_id, args.rerank_model, args.rerank_topn)\n        print(json.dumps(render_results(args.query, vec_doc_by_id, ranked, args.k), ensure_ascii=False, indent=2))\n        return\n\n    bm25_scores = score_bm25(bm25_idx, args.query, args.source)\n    vec_scores = score_vector(vidx, args.query, args.source)\n\n    bm25_n = normalize_scores(bm25_scores)\n    vec_n = normalize_scores(vec_scores)\n\n    all_ids = set(bm25_n.keys()) | set(vec_n.keys())\n    alpha = max(0.0, min(1.0, args.alpha))\n    fused = {i: alpha * bm25_n.get(i, 0.0) + (1 - alpha) * vec_n.get(i, 0.0) for i in all_ids}\n    ranked = sorted(fused.items(), key=lambda x: x[1], reverse=True)\n\n    merged_docs = bm25_doc_by_id | vec_doc_by_id\n    if args.rerank:\n        ranked = rerank_with_cross_encoder(args.query, ranked, merged_docs, args.rerank_model, args.rerank_topn)\n\n    result = render_results(args.query, merged_docs, ranked, args.k)\n    result['mode'] = 'hybrid'\n    result['alpha'] = alpha\n    result['bm25_backend'] = 'bm25'\n    result['vector_backend'] = vidx.get('meta', {}).get('backend')\n    result['rerank'] = bool(args.rerank)\n    if args.rerank:\n        result['rerank_model'] = args.rerank_model\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n\n\nif __name__ == '__main__':\n    main()\n"},"partialJson":"{\"file_path\":\"rag/index/query_rag.py\",\"content\":\"#!/usr/bin/env python3\\nfrom __future__ import annotations\\nfrom pathlib import Path\\nimport argparse\\nimport hashlib\\nimport json\\nimport math\\nimport re\\nfrom collections import Counter, defaultdict\\n\\nROOT = Path('/home/tiny4lurv/.openclaw/workspace')\\nBM25_INDEX = ROOT / 'rag' / 'index' / 'bm25_index.json'\\nVECTOR_INDEX = ROOT / 'rag' / 'index' / 'vector_index.json'\\nTOKEN_RE = re.compile(r\\\"[a-zA-Z][a-zA-Z0-9\\\\-]{1,}\\\")\\n\\nFALLBACK_DIMS = 768\\nNGRAM_MIN = 3\\nNGRAM_MAX = 5\\n\\n_ST_MODEL_CACHE = {}\\n\\n\\ndef tokenize(text: str):\\n    return [t.lower() for t in TOKEN_RE.findall(text)]\\n\\n\\ndef hash_feature(s: str, dims: int):\\n    h = hashlib.sha1(s.encode('utf-8')).digest()\\n    idx = int.from_bytes(h[:4], 'big') % dims\\n    sign = 1.0 if (h[4] & 1) == 0 else -1.0\\n    return idx, sign\\n\\n\\ndef char_ngrams(token: str):\\n    t = f\\\"^{token}$\\\"\\n    n = len(t)\\n    for k in range(NGRAM_MIN, NGRAM_MAX + 1):\\n        if n < k:\\n            continue\\n        for i in range(0, n - k + 1):\\n            yield t[i:i + k]\\n\\n\\ndef l2_normalize(v):\\n    norm = math.sqrt(sum(x * x for x in v))\\n    if norm == 0:\\n        return v\\n    return [x / norm for x in v]\\n\\n\\ndef fallback_query_vector(query: str, dims: int):\\n    toks = tokenize(query)\\n    tf = Counter(toks)\\n    vec = [0.0] * dims\\n    for tok, freq in tf.items():\\n        w = 1.0 + math.log(freq)\\n        idx, sign = hash_feature(f\\\"tok::{tok}\\\", dims)\\n        vec[idx] += sign * w\\n        for ng in char_ngrams(tok):\\n            ng_idx, ng_sign = hash_feature(f\\\"ng::{ng}\\\", dims)\\n            vec[ng_idx] += ng_sign * (w * 0.25)\\n    return l2_normalize(vec)\\n\\n\\ndef dot(a, b):\\n    return sum(x * y for x, y in zip(a, b))\\n\\n\\ndef normalize_scores(d):\\n    if not d:\\n        return {}\\n    vals = list(d.values())\\n    lo, hi = min(vals), max(vals)\\n    if hi <= lo:\\n        return {k: 1.0 for k in d}\\n    return {k: (v - lo) / (hi - lo) for k, v in d.items()}\\n\\n\\ndef score_bm25(idx: dict, query: str, source: str = 'both'):\\n    q_terms = tokenize(query)\\n    if not q_terms:\\n        return {}\\n\\n    df = idx['df']\\n    postings = idx['postings']\\n    docs = idx['docs']\\n    meta = idx['meta']\\n    N = meta['num_docs']\\n    avgdl = meta['avgdl']\\n    k1 = meta.get('k1', 1.5)\\n    b = meta.get('b', 0.75)\\n\\n    scores = defaultdict(float)\\n\\n    for term in q_terms:\\n        plist = postings.get(term)\\n        if not plist:\\n            continue\\n        n_qi = df.get(term, 0)\\n        idf = math.log(1 + (N - n_qi + 0.5) / (n_qi + 0.5))\\n        for dix, tf in plist:\\n            d = docs[dix]\\n            if source != 'both' and d['source_type'] != source:\\n                continue\\n            dl = d['len']\\n            denom = tf + k1 * (1 - b + b * (dl / avgdl))\\n            s = idf * ((tf * (k1 + 1)) / denom)\\n            scores[d['id']] += s\\n\\n    return dict(scores)\\n\\n\\ndef encode_query_transformer(query: str, model_name: str):\\n    try:\\n        from sentence_transformers import SentenceTransformer\\n    except Exception:\\n        return None\\n\\n    model = _ST_MODEL_CACHE.get(model_name)\\n    if model is None:\\n        model = SentenceTransformer(model_name)\\n        _ST_MODEL_CACHE[model_name] = model\\n\\n    vec = model.encode([query], normalize_embeddings=True, show_progress_bar=False)[0]\\n    return list(map(float, vec))\\n\\n\\ndef score_vector(vidx: dict, query: str, source: str = 'both'):\\n    docs = vidx['docs']\\n    vectors = vidx['vectors']\\n    meta = vidx.get('meta', {})\\n    backend = meta.get('backend', '')\\n    dims = int(meta.get('dims', FALLBACK_DIMS))\\n    model_name = meta.get('model')\\n\\n    qv = None\\n    if backend == 'sentence_transformers' and model_name:\\n        qv = encode_query_transformer(query, model_name)\\n\\n    if qv is None:\\n        qv = fallback_query_vector(query, dims)\\n\\n    scores = {}\\n    for d, dv in zip(docs, vectors):\\n        if source != 'both' and d['source_type'] != source:\\n            continue\\n        scores[d['id']] = dot(qv, dv)\\n    return scores\\n\\n\\ndef rerank_with_cross_encoder(query: str, candidates: list[tuple[str, float]], doc_by_id: dict, model_name: str, topn: int):\\n    try:\\n        from sentence_transformers import CrossEncoder\\n    except Exception:\\n        return candidates\\n\\n    head = candidates[:topn]\\n    if not head:\\n        return candidates\\n\\n    model = CrossEncoder(model_name)\\n    pairs = [(query, doc_by_id[doc_id]['text']) for doc_id, _ in head]\\n    scores = model.predict(pairs)\\n    reranked_head = sorted(\\n        [(doc_id, float(score)) for (doc_id, _), score in zip(head, scores)],\\n        key=lambda x: x[1],\\n        reverse=True,\\n    )\\n    tail = candidates[topn:]\\n    return reranked_head + tail\\n\\n\\ndef render_results(query: str, doc_by_id: dict, ranked_scores, k: int):\\n    out = []\\n    for doc_id, s in ranked_scores[:k]:\\n        d = doc_by_id[doc_id]\\n        snippet = d['text'][:400].replace('\\\\n', ' ')\\n        out.append({\\n            'score': round(s, 4),\\n            'id': d['id'],\\n            'path': d['path'],\\n            'source_type': d['source_type'],\\n            'chunk_index': d['chunk_index'],\\n            'snippet': snippet,\\n        })\\n    return {'query': query, 'results': out}\\n\\n\\ndef main():\\n    ap = argparse.ArgumentParser()\\n    ap.add_argument('query', type=str)\\n    ap.add_argument('-k', type=int, default=5)\\n    ap.add_argument('--source', choices=['both', 'website', 'docs'], default='both')\\n    ap.add_argument('--mode', choices=['bm25', 'vector', 'hybrid'], default='hybrid')\\n    ap.add_argument('--alpha', type=float, default=0.6, help='BM25 weight in hybrid mode (0..1)')\\n    ap.add_argument('--rerank', action='store_true', help='Apply cross-encoder reranking to fused top candidates')\\n    ap.add_argument('--rerank-model', default='BAAI/bge-reranker-base')\\n    ap.add_argument('--rerank-topn', type=int, default=20)\\n    args = ap.parse_args()\\n\\n    bm25_idx = json.loads(BM25_INDEX.read_text(encoding='utf-8'))\\n    bm25_docs = bm25_idx['docs']\\n    bm25_doc_by_id = {d['id']: d for d in bm25_docs}\\n\\n    if args.mode == 'bm25':\\n        bm25_scores = score_bm25(bm25_idx, args.query, args.source)\\n        ranked = sorted(bm25_scores.items(), key=lambda x: x[1], reverse=True)\\n        print(json.dumps(render_results(args.query, bm25_doc_by_id, ranked, args.k), ensure_ascii=False, indent=2))\\n        return\\n\\n    if not VECTOR_INDEX.exists():\\n        raise SystemExit('vector_index.json not found. Run build_vector_index.py first.')\\n    vidx = json.loads(VECTOR_INDEX.read_text(encoding='utf-8'))\\n    vec_docs = vidx['docs']\\n    vec_doc_by_id = {d['id']: d for d in vec_docs}\\n\\n    if args.mode == 'vector':\\n        vec_scores = score_vector(vidx, args.query, args.source)\\n        ranked = sorted(vec_scores.items(), key=lambda x: x[1], reverse=True)\\n        if args.rerank:\\n            ranked = rerank_with_cross_encoder(args.query, ranked, vec_doc_by_id, args.rerank_model, args.rerank_topn)\\n        print(json.dumps(render_results(args.query, vec_doc_by_id, ranked, args.k), ensure_ascii=False, indent=2))\\n        return\\n\\n    bm25_scores = score_bm25(bm25_idx, args.query, args.source)\\n    vec_scores = score_vector(vidx, args.query, args.source)\\n\\n    bm25_n = normalize_scores(bm25_scores)\\n    vec_n = normalize_scores(vec_scores)\\n\\n    all_ids = set(bm25_n.keys()) | set(vec_n.keys())\\n    alpha = max(0.0, min(1.0, args.alpha))\\n    fused = {i: alpha * bm25_n.get(i, 0.0) + (1 - alpha) * vec_n.get(i, 0.0) for i in all_ids}\\n    ranked = sorted(fused.items(), key=lambda x: x[1], reverse=True)\\n\\n    merged_docs = bm25_doc_by_id | vec_doc_by_id\\n    if args.rerank:\\n        ranked = rerank_with_cross_encoder(args.query, ranked, merged_docs, args.rerank_model, args.rerank_topn)\\n\\n    result = render_results(args.query, merged_docs, ranked, args.k)\\n    result['mode'] = 'hybrid'\\n    result['alpha'] = alpha\\n    result['bm25_backend'] = 'bm25'\\n    result['vector_backend'] = vidx.get('meta', {}).get('backend')\\n    result['rerank'] = bool(args.rerank)\\n    if args.rerank:\\n        result['rerank_model'] = args.rerank_model\\n    print(json.dumps(result, ensure_ascii=False, indent=2))\\n\\n\\nif __name__ == '__main__':\\n    main()\\n\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.3-codex","usage":{"input":202,"output":2970,"cacheRead":17920,"cacheWrite":0,"totalTokens":21092,"cost":{"input":0.0003535,"output":0.04158,"cacheRead":0.003136,"cacheWrite":0,"total":0.0450695}},"stopReason":"toolUse","timestamp":1773763614370}}
