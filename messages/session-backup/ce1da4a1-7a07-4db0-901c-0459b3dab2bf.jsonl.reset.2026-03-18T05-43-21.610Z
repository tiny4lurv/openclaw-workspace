ntent-Type': 'application/json'},\n        method='POST',\n    )\n    try:\n        with request.urlopen(req, timeout=600) as resp:\n            data = json.loads(resp.read().decode('utf-8'))\n    except Exception:\n        return None\n\n    embs = data.get('embeddings')\n    if not embs or len(embs) != len(records):\n        return None\n\n    embeddings = [l2_normalize(list(map(float, e))) for e in embs]\n","new_string":"def try_ollama_embeddings(records):\n    embeddings = []\n    batch_size = 48\n    for i in range(0, len(records), batch_size):\n        texts = [r['text'] for r in records[i:i + batch_size]]\n        payload = json.dumps({'model': OLLAMA_MODEL, 'input': texts}).encode('utf-8')\n        req = request.Request(\n            OLLAMA_URL,\n            data=payload,\n            headers={'Content-Type': 'application/json'},\n            method='POST',\n        )\n        try:\n            with request.urlopen(req, timeout=600) as resp:\n                data = json.loads(resp.read().decode('utf-8'))\n        except Exception:\n            return None\n\n        embs = data.get('embeddings')\n        if not embs or len(embs) != len(texts):\n            return None\n        embeddings.extend(l2_normalize(list(map(float, e))) for e in embs)\n\n"},"partialJson":"{\"file_path\":\"rag/index/build_vector_index.py\",\"old_string\":\"def try_ollama_embeddings(records):\\n    texts = [r['text'] for r in records]\\n    payload = json.dumps({'model': OLLAMA_MODEL, 'input': texts}).encode('utf-8')\\n    req = request.Request(\\n        OLLAMA_URL,\\n        data=payload,\\n        headers={'Content-Type': 'application/json'},\\n        method='POST',\\n    )\\n    try:\\n        with request.urlopen(req, timeout=600) as resp:\\n            data = json.loads(resp.read().decode('utf-8'))\\n    except Exception:\\n        return None\\n\\n    embs = data.get('embeddings')\\n    if not embs or len(embs) != len(records):\\n        return None\\n\\n    embeddings = [l2_normalize(list(map(float, e))) for e in embs]\\n\",\"new_string\":\"def try_ollama_embeddings(records):\\n    embeddings = []\\n    batch_size = 48\\n    for i in range(0, len(records), batch_size):\\n        texts = [r['text'] for r in records[i:i + batch_size]]\\n        payload = json.dumps({'model': OLLAMA_MODEL, 'input': texts}).encode('utf-8')\\n        req = request.Request(\\n            OLLAMA_URL,\\n            data=payload,\\n            headers={'Content-Type': 'application/json'},\\n            method='POST',\\n        )\\n        try:\\n            with request.urlopen(req, timeout=600) as resp:\\n                data = json.loads(resp.read().decode('utf-8'))\\n        except Exception:\\n            return None\\n\\n        embs = data.get('embeddings')\\n        if not embs or len(embs) != len(texts):\\n            return None\\n        embeddings.extend(l2_normalize(list(map(float, e))) for e in embs)\\n\\n\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.3-codex","usage":{"input":148,"output":496,"cacheRead":50560,"cacheWrite":0,"totalTokens":51204,"cost":{"input":0.000259,"output":0.006944,"cacheRead":0.008848,"cacheWrite":0,"total":0.016051}},"stopReason":"toolUse","timestamp":1773765613806}}
