lJson":"{\"file_path\":\"rag/RAG_OPERATOR_GUIDE.md\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.3-codex","usage":{"input":1844,"output":92,"cacheRead":10624,"cacheWrite":0,"totalTokens":12560,"cost":{"input":0.003227,"output":0.001288,"cacheRead":0.0018591999999999999,"cacheWrite":0,"total":0.0063742}},"stopReason":"toolUse","timestamp":1773763584693}}
{"type":"message","id":"c8b41b7a","parentId":"1ebc4d3b","timestamp":"2026-03-17T16:06:29.409Z","message":{"role":"toolResult","toolCallId":"call_15Dq0UekVrdQ2bTFwwwKlOOm|fc_0278252ab7917d830169b97c039ce88191a731fe25f549dec1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nfrom pathlib import Path\nimport hashlib\nimport json\nimport math\nimport re\nfrom collections import Counter, defaultdict\n\nROOT = Path('/home/tiny4lurv/.openclaw/workspace')\nCHUNKS = ROOT / 'rag' / 'index' / 'chunks.jsonl'\nOUT = ROOT / 'rag' / 'index' / 'vector_index.json'\nTOKEN_RE = re.compile(r\"[a-zA-Z][a-zA-Z0-9\\-]{1,}\")\n\n# Fallback params (stdlib-only semantic-ish hashing)\nFALLBACK_DIMS = 768\nNGRAM_MIN = 3\nNGRAM_MAX = 5\n\n\ndef tokenize(text: str):\n    return [t.lower() for t in TOKEN_RE.findall(text)]\n\n\ndef l2_normalize(v):\n    norm = math.sqrt(sum(x * x for x in v))\n    if norm == 0:\n        return v\n    return [x / norm for x in v]\n\n\ndef hash_feature(s: str, dims: int):\n    h = hashlib.sha1(s.encode('utf-8')).digest()\n    idx = int.from_bytes(h[:4], 'big') % dims\n    sign = 1.0 if (h[4] & 1) == 0 else -1.0\n    return idx, sign\n\n\ndef char_ngrams(token: str):\n    t = f\"^{token}$\"\n    n = len(t)\n    for k in range(NGRAM_MIN, NGRAM_MAX + 1):\n        if n < k:\n            continue\n        for i in range(0, n - k + 1):\n            yield t[i:i + k]\n\n\ndef build_fallback_embeddings(records):\n    # IDF on token-level to damp common vocabulary\n    df = defaultdict(int)\n    tokenized = []\n    for r in records:\n        toks = tokenize(r['text'])\n        tokenized.append(toks)\n        for t in set(toks):\n            df[t] += 1\n\n    N = max(1, len(records))\n\n    embeddings = []\n    for toks in tokenized:\n        vec = [0.0] * FALLBACK_DIMS\n        tf = Counter(toks)\n        for tok, freq in tf.items():\n            idf = math.log(1.0 + (N + 1) / (df[tok] + 1))\n            w = (1.0 + math.log(freq)) * idf\n            # token channel\n            idx, sign = hash_feature(f\"tok::{tok}\", FALLBACK_DIMS)\n            vec[idx] += sign * w\n            # char n-gram channel for soft lexical semantics / typo robustness\n            for ng in char_ngrams(tok):\n                ng_idx, ng_sign = hash_feature(f\"ng::{ng}\", FALLBACK_DIMS)\n                vec[ng_idx] += ng_sign * (w * 0.25)\n        embeddings.append(l2_normalize(vec))\n\n    return {\n        'backend': 'fallback_hash_embedding',\n        'dims': FALLBACK_DIMS,\n        'notes': (\n            'Approximate semantic proxy based on token+char-ngram signed hashing with IDF weighting. '\n            'No external ML dependencies; weaker true semantic capture than transformer embeddings.'\n        ),\n        'embeddings': embeddings,\n    }\n\n\ndef try_transformer_embeddings(records):\n    try:\n        from sentence_transformers import SentenceTransformer\n    except Exception:\n        return None\n\n    model_name = 'sentence-transformers/all-MiniLM-L6-v2'\n    model = SentenceTransformer(model_name)\n    texts = [r['text'] for r in records]\n    arr = model.encode(texts, normalize_embeddings=True, show_progress_bar=True)\n    embeddings = [list(map(float, row)) for row in arr]\n    dims = len(embeddings[0]) if embeddings else 0\n    return {\n        'backend': 'sentence_transformers',\n        'model': model_name,\n        'dims': dims,\n        'notes': 'Dense semantic embeddings from transformer model with cosine-ready normalized vectors.',\n        'embeddings': embeddings,\n    }\n\n\ndef main():\n    records = []\n    with CHUNKS.open('r', encoding='utf-8') as f:\n        for line in f:\n            r = json.loads(line)\n            records.append({\n                'id': r['id'],\n                'path': r['path'],\n                'source_type': r['source_type'],\n                'chunk_index': r['chunk_index'],\n                'text': r['text'],\n            })\n\n    if not records:\n        raise SystemExit('No chunk records found. Run build_chunks.py first.')\n\n    vec_data = try_transformer_embeddings(records)\n    if vec_data is None:\n        vec_data = build_fallback_embeddings(records)\n\n    out = {\n        'meta': {\n            'num_docs': len(records),\n            'backend': vec_data['backend'],\n            'dims': vec_data['dims'],\n            'notes': vec_data['notes'],\n        },\n        'docs': records,\n        'vectors': vec_data['embeddings'],\n    }\n    if 'model' in vec_data:\n        out['meta']['model'] = vec_data['model']\n\n    OUT.write_text(json.dumps(out, ensure_ascii=False), encoding='utf-8')\n    print(f\"Indexed {len(records)} vectors using {out['meta']['backend']} -> {OUT}\")\n\n\nif __name__ == '__main__':\n    main()\n"}],"isError":false,"timestamp":1773763589403}}
{"type":"message","id":"65a6551e","parentId":"c8b41b7a","timestamp":"2026-03-17T16:06:29.420Z","message":{"role":"toolResult","toolCallId":"call_uCTgEFcF2whwUdIPk3gxEhnV|fc_0278252ab7917d830169b97c039cf481919d3b4bf0c130e1b0","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\nfrom pathlib import Path\nimport argparse\nimport hashlib\nimport json\nimport math\nimport re\nfrom collections import Counter, defaultdict\n\nROOT = Path('/home/tiny4lurv/.openclaw/workspace')\nBM25_INDEX = ROOT / 'rag' / 'index' / 'bm25_index.json'\nVECTOR_INDEX = ROOT / 'rag' / 'index' / 'vector_index.json'\nTOKEN_RE = re.compile(r\"[a-zA-Z][a-zA-Z0-9\\-]{1,}\")\n\nFALLBACK_DIMS = 768\nNGRAM_MIN = 3\nNGRAM_MAX = 5\n\n\ndef tokenize(text: str):\n    return [t.lower() for t in TOKEN_RE.findall(text)]\n\n\ndef hash_feature(s: str, dims: int):\n    h = hashlib.sha1(s.encode('utf-8')).digest()\n    idx = int.from_bytes(h[:4], 'big') % dims\n    sign = 1.0 if (h[4] & 1) == 0 else -1.0\n    return idx, sign\n\n\ndef char_ngrams(token: str):\n    t = f\"^{token}$\"\n    n = len(t)\n    for k in range(NGRAM_MIN, NGRAM_MAX + 1):\n        if n < k:\n            continue\n        for i in range(0, n - k + 1):\n            yield t[i:i + k]\n\n\ndef l2_normalize(v):\n    norm = math.sqrt(sum(x * x for x in v))\n    if norm == 0:\n        return v\n    return [x / norm for x in v]\n\n\ndef fallback_query_vector(query: str, dims: int):\n    toks = tokenize(query)\n    tf = Counter(toks)\n    vec = [0.0] * dims\n    for tok, freq in tf.items():\n        w = 1.0 + math.log(freq)\n        idx, sign = hash_feature(f\"tok::{tok}\", dims)\n        vec[idx] += sign * w\n        for ng in char_ngrams(tok):\n            ng_idx, ng_sign = hash_feature(f\"ng::{ng}\", dims)\n            vec[ng_idx] += ng_sign * (w * 0.25)\n    return l2_normalize(vec)\n\n\ndef dot(a, b):\n    return sum(x * y for x, y in zip(a, b))\n\n\ndef normalize_scores(d):\n    if not d:\n        return {}\n    vals = list(d.values())\n    lo, hi = min(vals), max(vals)\n    if hi <= lo:\n        return {k: 1.0 for k in d}\n    return {k: (v - lo) / (hi - lo) for k, v in d.items()}\n\n\ndef score_bm25(idx: dict, query: str, source: str = 'both'):\n    q_terms = tokenize(query)\n    if not q_terms:\n        return {}\n\n    df = idx['df']\n    postings = idx['postings']\n    docs = idx['docs']\n    meta = idx['meta']\n    N = meta['num_docs']\n    avgdl = meta['avgdl']\n    k1 = meta.get('k1', 1.5)\n    b = meta.get('b', 0.75)\n\n    scores = defaultdict(float)\n\n    for term in q_terms:\n        plist = postings.get(term)\n        if not plist:\n            continue\n        n_qi = df.get(term, 0)\n        idf = math.log(1 + (N - n_qi + 0.5) / (n_qi + 0.5))\n        for dix, tf in plist:\n            d = docs[dix]\n            if source != 'both' and d['source_type'] != source:\n                continue\n            dl = d['len']\n            denom = tf + k1 * (1 - b + b * (dl / avgdl))\n            s = idf * ((tf * (k1 + 1)) / denom)\n            scores[d['id']] += s\n\n    return dict(scores)\n\n\ndef score_vector(vidx: dict, query: str, source: str = 'both'):\n    docs = vidx['docs']\n    vectors = vidx['vectors']\n    backend = vidx.get('meta', {}).get('backend', '')\n    dims = int(vidx.get('meta', {}).get('dims', FALLBACK_DIMS))\n\n    qv = fallback_query_vector(query, dims)\n    if backend != 'fallback_hash_embedding':\n        # Transformer embeddings were built offline; query-time fallback keeps the pipeline functional\n        # without forcing runtime heavy dependencies.\n        qv = fallback_query_vector(query, dims)\n\n    scores = {}\n    for d, dv in zip(docs, vectors):\n        if source != 'both' and d['source_type'] != source:\n            continue\n        scores[d['id']] = dot(qv, dv)\n    return scores\n\n\ndef render_results(query: str, doc_by_id: dict, ranked_scores, k: int):\n    out = []\n    for doc_id, s in ranked_scores[:k]:\n        d = doc_by_id[doc_id]\n        snippet = d['text'][:400].replace('\\n', ' ')\n        out.append({\n            'score': round(s, 4),\n            'id': d['id'],\n            'path': d['path'],\n            'source_type': d['source_type'],\n            'chunk_index': d['chunk_index'],\n            'snippet': snippet,\n        })\n    return {'query': query, 'results': out}\n\n\ndef main():\n    ap = argparse.ArgumentParser()\n    ap.add_argument('query', type=str)\n    ap.add_argument('-k', type=int, default=5)\n    ap.add_argument('--source', choices=['both', 'website', 'docs'], default='both')\n    ap.add_argument('--mode', choices=['bm25', 'vector', 'hybrid'], default='hybrid')\n    ap.add_argument('--alpha', type=float, default=0.6, help='BM25 weight in hybrid mode (0..1)')\n    args = ap.parse_args()\n\n    bm25_idx = json.loads(BM25_INDEX.read_text(encoding='utf-8'))\n    bm25_docs = bm25_idx['docs']\n    bm25_doc_by_id = {d['id']: d for d in bm25_docs}\n\n    if args.mode == 'bm25':\n        bm25_scores = score_bm25(bm25_idx, args.query, args.source)\n        ranked = sorted(bm25_scores.items(), key=lambda x: x[1], reverse=True)\n        print(json.dumps(render_results(args.query, bm25_doc_by_id, ranked, args.k), ensure_ascii=False, indent=2))\n        return\n\n    if not VECTOR_INDEX.exists():\n        raise SystemExit('vector_index.json not found. Run build_vector_index.py first.')\n    vidx = json.loads(VECTOR_INDEX.read_text(encoding='utf-8'))\n    vec_docs = vidx['docs']\n    vec_doc_by_id = {d['id']: d for d in vec_docs}\n\n    if args.mode == 'vector':\n        vec_scores = score_vector(vidx, args.query, args.source)\n        ranked = sorted(vec_scores.items(), key=lambda x: x[1], reverse=True)\n        print(json.dumps(render_results(args.query, vec_doc_by_id, ranked, args.k), ensure_ascii=False, indent=2))\n        return\n\n    bm25_scores = score_bm25(bm25_idx, args.query, args.source)\n    vec_scores = score_vector(vidx, args.query, args.source)\n\n    bm25_n = normalize_scores(bm25_scores)\n    vec_n = normalize_scores(vec_scores)\n\n    all_ids = set(bm25_n.keys()) | set(vec_n.keys())\n    alpha = max(0.0, min(1.0, args.alpha))\n    fused = {i: alpha * bm25_n.get(i, 0.0) + (1 - alpha) * vec_n.get(i, 0.0) for i in all_ids}\n    ranked = sorted(fused.items(), key=lambda x: x[1], reverse=True)\n\n    result = render_results(args.query, bm25_doc_by_id | vec_doc_by_id, ranked, args.k)\n    result['mode'] = 'hybrid'\n    result['alpha'] = alpha\n    result['bm25_backend'] = 'bm25'\n    result['vector_backend'] = vidx.get('meta', {}).get('backend')\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n\n\nif __name__ == '__main__':\n    main()\n"}],"isError":false,"timestamp":1773763589415}}
{"type":"message","id":"c681ff65","parentId":"65a6551e","timestamp":"2026-03-17T16:06:29.433Z","message":{"role":"toolResult","toolCallId":"call_l7tgPzXenKXHNIwRqF9jWcpx|fc_0278252ab7917d830169b97c039cfc8191a43cabbe14b66561","toolName":"read","content":[{"type":"text","text":"# Nava RAG Operator Guide (v2)\n\n## What exists now\n- Unified chunk corpus: `rag/index/chunks.jsonl`\n- Retrieval indices:\n  - BM25 lexical: `rag/index/bm25_index.json`\n  - Vector: `rag/index/vector_index.json`\n- Build scripts:\n  - `rag/index/build_chunks.py`\n  - `rag/index/build_bm25.py`\n  - `rag/index/build_vector_index.py`\n- Query script:\n  - `rag/index/query_rag.py`\n\n## Rebuild pipeline\n```bash\npython3 rag/index/build_chunks.py\npython3 rag/index/build_bm25.py\npython3 rag/index/build_vector_index.py\n```\n\n## Query examples\n```bash\n# Hybrid retrieval (recommended)\npython3 rag/index/query_rag.py \"healthcare staffing trust deficits\" -k 5 --mode hybrid\n\n# BM25 only\npython3 rag/index/query_rag.py \"bilingual clinicians\" -k 5 --mode bm25 --source website\n\n# Vector only\npython3 rag/index/query_rag.py \"convert agency staff to permanent team\" -k 5 --mode vector\n\n# Hybrid with custom BM25 weight\npython3 rag/index/query_rag.py \"reactive recruitment fails\" -k 8 --mode hybrid --alpha 0.65\n```\n\n## Current schema\nEach chunk includes:\n- `id`\n- `path`\n- `source_type` (`website` or `docs`)\n- `chunk_index`\n- `text`\n\n## Vector backend behavior\n- Preferred backend: `sentence-transformers` (if installed at build time).\n- Fallback backend (implemented): `fallback_hash_embedding` using stdlib-only signed hash vectors + char n-grams.\n- Why fallback exists: keeps retrieval operational in dependency-constrained environments.\n- Constraint: fallback is weaker than transformer embeddings on deep paraphrase semantics.\n\n## Notes\n- v2 retrieval supports `--mode bm25|vector|hybrid`.\n- Hybrid uses normalized score fusion with `--alpha` as BM25 weight.\n- For production hardening, see: `rag/PRODUCTION_RAG_BEST_PRACTICES.md`.\n"}],"isError":false,"timestamp":1773763589427}}
