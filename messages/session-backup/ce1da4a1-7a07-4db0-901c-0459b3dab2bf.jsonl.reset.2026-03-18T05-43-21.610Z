{"type":"message","id":"05ee3066","parentId":"7ffde485","timestamp":"2026-03-17T15:17:15.579Z","message":{"role":"toolResult","toolCallId":"call_w6KU7B5wVOXAJNl9U6KVEl6f|fc_0278252ab7917d830169b9707b7dd08191a4f6466eaf24d522","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom pathlib import Path\nimport json\n\nROOT = Path('/home/tiny4lurv/.openclaw/workspace')\nSRC_DIRS = [\n    ROOT / 'rag' / 'clean_txt',\n    ROOT / 'docs',\n    ROOT / 'docs' / 'converted',\n]\nOUT = ROOT / 'rag' / 'index' / 'chunks.jsonl'\n\n\ndef chunk_text(text: str, size: int = 1400, overlap: int = 200):\n    chunks = []\n    i = 0\n    n = len(text)\n    while i < n:\n        j = min(i + size, n)\n        chunks.append(text[i:j])\n        if j == n:\n            break\n        i = max(0, j - overlap)\n    return chunks\n\n\ndef iter_files():\n    for d in SRC_DIRS:\n        if not d.exists():\n            continue\n        for p in sorted(d.rglob('*')):\n            if p.is_file() and p.suffix.lower() in {'.md', '.txt'}:\n                yield p\n\n\ndef main():\n    OUT.parent.mkdir(parents=True, exist_ok=True)\n    count = 0\n    with OUT.open('w', encoding='utf-8') as f:\n        for p in iter_files():\n            text = p.read_text(encoding='utf-8', errors='ignore').strip()\n            if not text:\n                continue\n            rel = str(p.relative_to(ROOT))\n            source_type = 'website' if rel.startswith('rag/clean_txt') else 'docs'\n            for idx, ch in enumerate(chunk_text(text)):\n                rec = {\n                    'id': f'{rel}::chunk::{idx}',\n                    'path': rel,\n                    'source_type': source_type,\n                    'chunk_index': idx,\n                    'text': ch,\n                }\n                f.write(json.dumps(rec, ensure_ascii=False) + '\\n')\n                count += 1\n    print(count)\n\n\nif __name__ == '__main__':\n    main()\n"}],"isError":false,"timestamp":1773760635570}}
