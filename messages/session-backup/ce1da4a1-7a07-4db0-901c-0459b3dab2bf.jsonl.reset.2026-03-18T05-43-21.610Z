navahc_com_hard_to_fill_leadership_roles_in_healthcare.md\n/rag/clean_md/3_navahc_com_building_a_healthcare_talent_pipeline.md\n/rag/clean_md/5_navahc_com_compliance_in_healthcare_staffing.md\n/rag/clean_md/15_navahc_com_how_to_find_the_best_medical_recruiting_agencies.md\n/rag/clean_md/8_navahc_com_healthcare_hiring_without_guesswork.md\n/rag/clean_md/9_navahc_com_healthcare_recruitment_agencies_trust_deficits.md\n/rag/clean_md/4_navahc_com_cms_staffing_requirements.md\n/rag/clean_md/11_navahc_com_healthcare_workforce_partnership_models.md\n/rag/clean_md/22_navahc_com_your_favorite_healthcare_staffing_fails.md\n/rag/clean_md/18_navahc_com_relational_healthcare_staffing_and_recruiting.md\n/rag/clean_md/12_navahc_com_how_medical_staffing_became_a_liability.md\n/rag/clean_md/6_navahc_com_fix_your_flexible_staffing_model_in_healthcare.md\n/rag/clean_md/20_navahc_com_why_job_boards_fail_healthcare_recruiters.md\n/rag/article_index.md\n/rag/SYNTHESIS_v1.md\n/rag/synthesis/NAVA_SYNTHESIS.md\n/rag/synthesis/Nava_Website_Synthesis_v1.md\n/rag/synthesis/initial_synthesis.md\n/rag/synthesis/Nava_Contradiction_Gap_Matrix_v1.md\n/rag/PRODUCTION_RAG_BEST_PRACTICES.md","cwd":"/home/tiny4lurv/.openclaw/workspace"},"isError":false,"timestamp":1773763584688}}
