{"type":"message","id":"eb17d338","parentId":"919defe6","timestamp":"2026-04-07T21:53:12.990Z","message":{"role":"assistant","content":[{"type":"text","text":"Now fix thesis_clarity.py — the hook in paragraph 1 isn't being excluded because the hook check happens after paragraph scoring, and the first paragraph's first sentence is being picked as a \"claim\":\n"},{"type":"toolCall","id":"ollama_call_94b26af8-e4d3-4fee-ab92-95d3eb255185","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\nThesis Clarity Analyzer (B1)\nDetects presence and strength of central claim.\n\nFor LinkedIn/X (short-form):\n  - The OPENING LINE is the hook+thesis combined — it names a phenomenon, creates curiosity\n  - Body paragraphs that \"explain\" the hook are NOT new thesis candidates\n  - The LAST paragraph is the landing — not a thesis candidate\n  - The real thesis is somewhere in paragraphs 2-5: a declarative statement that makes a claim\n\nFor blog/essay (long-form): traditional thesis detection.\n\nHook patterns (skip for thesis detection in short-form):\n  - Questions\n  - \"When X...\" observational/teaser openings\n  - \"Here is what...\" / \"Here is why...\" explanatory framings\n  - Short (<=5 words) standalone lines\n\"\"\"\nimport re\nimport json\nimport sys\nfrom typing import Dict, Any, List, Tuple\n\n# ─── Hook patterns for short-form ─────────────────────────────────────────────\nSHORTFORM_HOOK_PATTERNS = [\n    r'\\?$',\n    r'^what\\s+', r'^why\\s+', r'^how\\s+', r'^when\\s+', r'^if\\s+',\n    r\"^when an industry\", r\"^what happens when\",\n    r\"^here('s| is) the (thing|truth|problem|secret)\",\n    r\"^what nobody\", r\"^the real\", r\"^the hidden\", r\"^the unspoken\",\n    r\"^the inconvenient\", r\"^what i learned\", r\"^what they don't\",\n    r\"^the problem with\", r\"^turns out\", r\"^it turns out\",\n    r\"^surprising\", r\"^curiously\", r\"^remarkably\", r\"^interestingly\",\n    r\"^the fact is\", r\"^the reality is\", r\"^the problem isn('t| not)\",\n    r\"^this is (why|how|the)\", r\"^here('s| is) (why|what|how)\"\n]\n\n\ndef is_hook_sentence(sentence: str) -> bool:\n    \"\"\"Returns True if sentence looks like a hook opening.\"\"\"\n    s = sentence.strip().lower()\n    if len(s.split()) <= 5:\n        return True\n    for pattern in SHORTFORM_HOOK_PATTERNS:\n        if re.search(pattern, s):\n            return True\n    return False\n\n\ndef is_explanatory_framing(sentence: str) -> bool:\n    \"\"\"\n    Returns True if this sentence is explaining what comes next — not making a claim.\n    These are NOT thesis candidates.\n    \"\"\"\n    s = sentence.lower()\n    explanatory = [\n        \"here's what\", \"here is what\", \"here's why\", \"here is why\",\n        \"what this means\", \"what that means\", \"what i mean is\",\n        \"let me explain\", \"what i'm talking about\", \"to be clear\",\n        \"to understand\", \"the point is\", \"the thing is\", \"basically\",\n        \"essentially\", \"in other words\", \"that is to say\"\n    ]\n    return any(phrase in s for phrase in explanatory)\n\n\ndef extract_declarative_sentences(paragraph: str) -> List[str]:\n    \"\"\"Extract sentences that look like claim candidates (declarative, not questions).\"\"\"\n    sentences = re.split(r'[.!?]+', paragraph)\n    candidates = []\n    for s in sentences:\n        s = s.strip()\n        if not s or len(s.split()) < 4:\n            continue\n        if s.strip().endswith('?'):\n            continue\n        if is_explanatory_framing(s):\n            continue\n        # Must contain at least one declarative indicator\n        lower = s.lower()\n        indicators = ['is', 'are', 'will', 'must', 'should', 'can', 'cannot',\n                      'leads', 'results', 'shows', 'demonstrates', 'proves',\n                      'this', 'that', 'these', 'those', 'the']\n        if any(word in lower for word in indicators):\n            candidates.append(s)\n    return candidates\n\n\ndef analyze(text: str, format_hint: str = \"generic\", format_profile: Dict = None) -> Dict[str, Any]:\n    \"\"\"\n    Main entry point.\n    Returns score 0.0-1.0 where 1.0 = clear, single, defensible thesis.\n    \"\"\"\n    if not text.strip():\n        return {\n            \"dimension\": \"B1\", \"dimension_name\": \"Thesis Clarity\", \"score\": 0.0,\n            \"verdict\": \"fail\", \"confidence\": 0.9,\n            \"evidence\": [{\"passage\": \"\", \"location\": \"document\", \"signal\": \"No text provided\", \"severity\": \"error\"}],\n            \"interpretation\": \"Empty text.\", \"recommendation\": \"Provide content to evaluate.\"\n        }\n\n    is_shortform = (len(text.strip()) < 2500) or (format_hint in [\"linkedin\", \"x_thread\", \"copywriting\"])\n\n    paragraphs = re.split(r'\\n\\s*\\n', text.strip())\n    paragraphs = [p.strip() for p in paragraphs if p.strip()]\n\n    if not paragraphs:\n        return {\n            \"dimension\": \"B1\", \"dimension_name\": \"Thesis Clarity\", \"score\": 0.0,\n            \"verdict\": \"fail\", \"confidence\": 0.9,\n            \"evidence\": [{\"passage\": \"\", \"location\": \"document\", \"signal\": \"No paragraphs found\", \"severity\": \"error\"}],\n            \"interpretation\": \"No discernible structure.\", \"recommendation\": \"Organize content into paragraphs.\"\n        }\n\n    # ── SHORT-FORM: opening line = hook+thesis. Last paragraph = landing. ────────\n    if is_shortform:\n        candidates = []\n        first_para_sentences = re.split(r'[.!?]+', paragraphs[0])\n        first_para_sentences = [s.strip() for s in first_para_sentences if s.strip()]\n\n        if first_para_sentences:\n            first = first_para_sentences[0]\n            # Opening line IS the hook+thesis. Use it.\n            if is_hook_sentence(first) or is_explanatory_framing(first):\n                # Hook detected — treat as intentional, give credit\n                candidates.append({\n                    \"text\": first,\n                    \"paragraph\": 0,\n                    \"is_first\": True,\n                    \"role\": \"hook+thesis\"\n                })\n            else:\n                candidates.append({\n                    \"text\": first,\n                    \"paragraph\": 0,\n                    \"is_first\": True,\n                    \"role\": \"thesis\"\n                })\n\n        # Body paragraphs (2 through n-1): look for declarative claim sentences\n        for pi in range(1, len(paragraphs) - 1):\n            decls = extract_declarative_sentences(paragraphs[pi])\n            for d in decls[:2]:  # take up to 2 per paragraph\n                candidates.append({\n                    \"text\": d,\n                    \"paragraph\": pi,\n                    \"is_first\": False,\n                    \"role\": \"body_claim\"\n                })\n\n        # Dedup\n        seen = set()\n        unique = []\n        for c in candidates:\n            key = c[\"text\"][:60].lower()\n            if key not in seen:\n                seen.add(key)\n                unique.append(c)\n\n        score = 1.0\n        issues = []\n\n        if len(unique) == 0:\n            score = 0.3\n            issues.append((\"no_thesis\", \"No thesis-like statement detected\"))\n        elif len(unique) == 1:\n            score = 0.9  # Clean — one thesis, well-placed\n        else:\n            # Multiple body claims — check if they develop the same argument\n            # Accept up to 2 body claims without penalty if they're in the same paragraph\n            body_claims = [c for c in unique if c[\"role\"] == \"body_claim\"]\n            if len(body_claims) <= 2:\n                score = 0.8  # Minor, acceptable\n            else:\n                score = 0.5\n                issues.append((\"multiple_theses\", f\"{len(unique)} potential thesis statements — body may have competing claims\"))\n\n        score = max(0.0, min(1.0, score))\n        verdict = \"pass\" if score >= 0.8 else (\"warning\" if score >= 0.5 else \"fail\")\n        confidence = 0.85\n\n        evidence = []\n        if unique:\n            evidence.append({\n                \"passage\": unique[0][\"text\"][:200],\n                \"location\": f\"paragraph {unique[0]['paragraph']+1} ({unique[0]['role']})\",\n                \"signal\": f\"Thesis/hook: '{unique[0]['text'][:80]}...'\",\n                \"severity\": \"info\"\n            })\n            if len(unique) > 1:\n                body = [c for c in unique if c[\"role\"] == \"body_claim\"]\n                if body:\n                    evidence.append({\n                        \"passage\": body[0][\"text\"][:200],\n                        \"location\": f\"paragraph {body[0]['paragraph']+1}\",\n                        \"signal\": f\"Body claim: '{body[0]['text'][:80]}...'\",\n                        \"severity\": \"info\"\n                    })\n                if len(unique) > 3:\n                    evidence.append({\n                        \"passage\": f\"{len(unique)} total thesis-like statements detected\",\n                        \"location\": \"document\",\n                        \"signal\": \"thesis_conflict_explanation\",\n                        \"severity\": \"warning\"\n                    })\n\n        if verdict == \"pass\":\n            interpretation = \"Single clear thesis detected (opening line = hook+thesis).\"\n            recommendation = \"Thesis is strong.\"\n        elif verdict == \"warning\":\n            if len(unique) == 1:\n                interpretation = \"Thesis present but may lack specificity.\"\n                recommendation = \"Ensure thesis is specific, defensible, and addressed throughout.\"\n            else:\n                interpretation = f\"Multiple thesis-like statements detected ({len(unique)}). This may be acceptable for narrative posts.\"\n                recommendation = \"In short-form: the opening line is hook+thesis. Body paragraphs should develop it, not introduce new claims. Merge or cut secondary claims.\"\n        else:\n            interpretation = \"No clear thesis detected.\"\n            recommendation = \"State your central claim in the opening line.\"\n\n        return {\n            \"dimension\": \"B1\", \"dimension_name\": \"Thesis Clarity\",\n            \"score\": round(score, 3), \"verdict\": verdict, \"confidence\": confidence,\n            \"evidence\": evidence, \"interpretation\": interpretation,\n            \"recommendation\": recommendation\n        }\n\n    # ── LONG-FORM: traditional thesis detection ─────────────────────────────────\n    full_text = ' '.join(paragraphs).lower()\n    claim_indicators = [\n        r'\\bis\\b', r'\\bare\\b', r'\\bwill\\b', r'\\bmust\\b', r'\\bshould\\b',\n        r'\\bcauses\\b', r'\\bleads to\\b', r'\\bshows that\\b',\n        r'\\bdemonstrates that\\b', r'\\bevidence suggests\\b', r'\\bstudy indicates\\b'\n    ]\n\n    found_thesis = False\n    thesis_text = \"\"\n    thesis_para = 0\n\n    for pi, para in enumerate(paragraphs[:3]):\n        for sent in re.split(r'[.!?]+', para):\n            sent = sent.strip()\n            if not sent or len(sent.split()) < 5:\n                continue\n            if any(re.search(p, sent.lower()) for p in claim_indicators):\n                found_thesis = True\n                thesis_text = sent\n                thesis_para = pi\n                break\n        if found_thesis:\n            break\n\n    if not found_thesis:\n        return {\n            \"dimension\": \"B1\", \"dimension_name\": \"Thesis Clarity\", \"score\": 0.3,\n            \"verdict\": \"fail\", \"confidence\": 0.85,\n            \"evidence\": [{\"passage\": paragraphs[0][:100], \"location\": \"paragraph 1\", \"signal\": \"No clear thesis detected\", \"severity\": \"warning\"}],\n            \"interpretation\": \"No clear thesis in first three paragraphs.\",\n            \"recommendation\": \"State your central claim clearly near the beginning.\"\n        }\n\n    # Check if conclusion resolves thesis\n    conclusion = paragraphs[-1].lower()\n    thesis_words = set(re.findall(r'\\b\\w{4,}\\b', thesis_text.lower()))\n    conclusion_words = set(re.findall(r'\\b\\w{4,}\\b', conclusion))\n    overlap = len(thesis_words & conclusion_words)\n    score = 0.9 if overlap >= 2 else 0.7\n\n    verdict = \"pass\" if score >= 0.8 else \"warning\"\n\n    return {\n        \"dimension\": \"B1\", \"dimension_name\": \"Thesis Clarity\",\n        \"score\": round(score, 3), \"verdict\": verdict, \"confidence\": 0.85,\n        \"evidence\": [{\"passage\": thesis_text[:200], \"location\": f\"paragraph {thesis_para+1}\", \"signal\": \"Thesis detected\", \"severity\": \"info\"}],\n        \"interpretation\": \"Clear thesis detected.\",\n        \"recommendation\": \"Thesis is strong and clear.\"\n    }\n\n\nif __name__ == \"__main__\":\n    if len(sys.argv) > 1:\n        text = \" \".join(sys.argv[1:])\n    else:\n        text = sys.stdin.read().strip()\n    result = analyze(text)\n    print(json.dumps(result, indent=2))\n","path":"/home/tiny4lurv/.openclaw/workspace/tinyqe/analyzers/thesis_clarity.py"}}],"stopReason":"toolUse","api":"ollama","provider":"ollama","model":"minimax-m2.7:cloud","usage":{"input":74450,"output":3614,"cacheRead":0,"cacheWrite":0,"totalTokens":78064,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"timestamp":1775598792988}}
{"type":"message","id":"4d6b0255","parentId":"eb17d338","timestamp":"2026-04-07T21:53:13.065Z","message":{"role":"toolResult","toolCallId":"ollama_call_94b26af8-e4d3-4fee-ab92-95d3eb255185","toolName":"write","content":[{"type":"text","text":"Successfully wrote 11824 bytes to /home/tiny4lurv/.openclaw/workspace/tinyqe/analyzers/thesis_clarity.py"}],"isError":false,"timestamp":1775598793029}}
{"type":"message","id":"61a00e92","parentId":"4d6b0255","timestamp":"2026-04-07T21:53:23.159Z","message":{"role":"assistant","content":[{"type":"text","text":"Now test again:\n"},{"type":"toolCall","id":"ollama_call_3cb02f2d-fa04-4fba-9135-75da3f604ae3","name":"exec","arguments":{"command":"cd /home/tiny4lurv/.openclaw/workspace && python3 tinyqe/tinyqe.py --format json << 'POST'\nWhen an industry treats a nursing strike as a revenue line item, perhaps the system is working exactly as designed.\n\nHere is what that phrase actually means in practice. When hospitals face staffing shortages or nurses go on strike, they call an agency to fill those shifts. The agency charges a premium for the emergency coverage. AMN Healthcare calls that premium \"labor disruption revenue.\" On their February 2025 earnings call, CEO Cary Grace announced they beat their own projection on that line by $22 million. The strikes happened. They collected.\n\nThe spread between what agencies charge hospitals and what they pay nurses is where the margin lives. Cross Country Healthcare put it plainly on an earnings call: they manage bill rates to hospitals against nurse pay expectations. Those are the two blades of the same scissors, and the gap between them is not accidental. In California, contract nursing rates reached $116 per hour in 2023, up from $81 in 2019. That $35 escalation did not flow to nurses. It flowed to agency margins. AMN's gross margin in 2024 was 30.8% on $2.98 billion in revenue.\n\nHospital systems are now running from the model. Universal Health Services' CFO named it explicitly: lower premium labor is the core driver of their EBITDA growth. HCA is building internal nursing pipelines to stop paying agency markups. Tenet cut contract labor and absorbed a 200 basis point margin compression in the transition. The math only works because the alternative is worse.\n\nThese are not systems failing to solve a problem. They are systems recognising that the problem is the model. Exactly as designed.\n\nThis is why Nava operates on two parallel tracks. Reclaimix converts agency nurses already in your building into permanent staff — eliminating the markup on the people you depend on today. NurseSphere builds a multi-year international clinical baseline — so you stop renting strangers at crisis rates and start owning a workforce that knows your patients, your systems, and your team. The markup was never inevitable. It was a structural choice made by an industry that had no incentive to give you a better option. NaVa built both tracks because the crisis did not arrive from one direction, and neither does the exit.\n\nThe facilities that have done the work are not going back. The model was never built for you.\nPOST","timeout":30}}],"stopReason":"toolUse","api":"ollama","provider":"ollama","model":"minimax-m2.7:cloud","usage":{"input":74549,"output":554,"cacheRead":0,"cacheWrite":0,"totalTokens":75103,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"timestamp":1775598803156}}
{"type":"message","id":"61a6b746","parentId":"61a00e92","timestamp":"2026-04-07T21:53:23.423Z","message":{"role":"toolResult","toolCallId":"ollama_call_3cb02f2d-fa04-4fba-9135-75da3f604ae3","toolName":"exec","content":[{"type":"text","text":"{\n  \"evaluation_id\": \"0dcc6f52-d58b-4b29-a7f6-c1ac091ce42c\",\n  \"timestamp\": \"2026-04-07T21:53:23.409378Z\",\n  \"format_detected\": \"linkedin\",\n  \"format_confidence\": 0.85,\n  \"overall_snapshot\": {\n    \"weighted_score\": 0.76,\n    \"verdict\": \"warning\",\n    \"one_liner\": \"Strong thesis clarity; needs work on evidence quality, platform reach potential.\"\n  },\n  \"dimension_results\": [\n    {\n      \"dimension\": \"A1\",\n      \"dimension_name\": \"Linguistic Integrity\",\n      \"score\": 0.884,\n      \"verdict\": \"pass\",\n      \"confidence\": 0.95,\n      \"evidence\": [\n        {\n          \"passage\": \"e.\\\"\",\n          \"location\": \"char 390-393\",\n          \"signal\": \"missing space after period\",\n          \"severity\": \"error\"\n        },\n        {\n          \"passage\": \"an i\",\n          \"location\": \"char 5-9\",\n          \"signal\": \"use 'a' before consonant sound\",\n          \"severity\": \"warning\"\n        },\n        {\n          \"passage\": \"an a\",\n          \"location\": \"char 243-247\",\n          \"signal\": \"use 'a' before consonant sound\",\n          \"severity\": \"warning\"\n        },\n        {\n          \"passage\": \"an e\",\n          \"location\": \"char 701-705\",\n          \"signal\": \"use 'a' before consonant sound\",\n          \"severity\": \"warning\"\n        },\n        {\n          \"passage\": \"an i\",\n          \"location\": \"char 2080-2084\",\n          \"signal\": \"use 'a' before consonant sound\",\n          \"severity\": \"warning\"\n        }\n      ],\n      \"interpretation\": \"9 mechanical errors detected. Highest priority: missing space after period\",\n      \"recommendation\": \"Address errors in order: missing space after period, use 'a' before consonant sound, use 'a' before consonant sound\"\n    },\n    {\n      \"dimension\": \"A2\",\n      \"dimension_name\": \"Readability Floor\",\n      \"score\": 1.0,\n      \"verdict\": \"pass\",\n      \"confidence\": 0.9,\n      \"evidence\": [\n        {\n          \"passage\": \"FKGL: 7.6, FRE: 61.2, SMOG: 10.7\",\n          \"location\": \"document\",\n          \"signal\": \"Grade level 7.6 (optimal: 7.0-8.5)\",\n          \"severity\": \"info\"\n        }\n      ],\n      \"interpretation\": \"Readability is appropriate for target audience (FKGL 7.6).\",\n      \"recommendation\": \"No changes needed for readability.\"\n    },\n    {\n      \"dimension\": \"B1\",\n      \"dimension_name\": \"Thesis Clarity\",\n      \"score\": 0.5,\n      \"verdict\": \"warning\",\n      \"confidence\": 0.85,\n      \"evidence\": [\n        {\n          \"passage\": \"When an industry treats a nursing strike as a revenue line item, perhaps the system is working exactly as designed\",\n          \"location\": \"paragraph 1 (hook+thesis)\",\n          \"signal\": \"Thesis/hook: 'When an industry treats a nursing strike as a revenue line item, perhaps the sys...'\",\n          \"severity\": \"info\"\n        },\n        {\n          \"passage\": \"When hospitals face staffing shortages or nurses go on strike, they call an agency to fill those shifts\",\n          \"location\": \"paragraph 2\",\n          \"signal\": \"Body claim: 'When hospitals face staffing shortages or nurses go on strike, they call an agen...'\",\n          \"severity\": \"info\"\n        },\n        {\n          \"passage\": \"11 total thesis-like statements detected\",\n          \"location\": \"document\",\n          \"signal\": \"thesis_conflict_explanation\",\n          \"severity\": \"warning\"\n        }\n      ],\n      \"interpretation\": \"Multiple thesis-like statements detected (11). This may be acceptable for narrative posts.\",\n      \"recommendation\": \"In short-form: the opening line is hook+thesis. Body paragraphs should develop it, not introduce new claims. Merge or cut secondary claims.\"\n    },\n    {\n      \"dimension\": \"B2\",\n      \"dimension_name\": \"Logical Flow\",\n      \"score\": 0.0,\n      \"verdict\": \"fail\",\n      \"confidence\": 0.85,\n      \"evidence\": [\n        {\n          \"passage\": \"Here is what that phrase actually means in practice.\",\n          \"location\": \"sentence 2\",\n          \"signal\": \"No clear transition to previous sentence\",\n          \"severity\": \"warning\"\n        },\n        {\n          \"passage\": \"When hospitals face staffing shortages or nurses go on strike, they call an agency to fill those shifts.\",\n          \"location\": \"sentence 3\",\n          \"signal\": \"No clear transition to previous sentence\",\n          \"severity\": \"warning\"\n        }\n      ],\n      \"interpretation\": \"Logical flow is fragmented \\u2014 many sentences lack clear connections.\",\n      \"recommendation\": \"Add transition words to guide the reader through your argument. Consider outlining first to ensure logical progression.\"\n    },\n    {\n      \"dimension\": \"B3\",\n      \"dimension_name\": \"Structural Completeness\",\n      \"score\": 1.0,\n      \"verdict\": \"pass\",\n      \"confidence\": 0.8,\n      \"evidence\": [\n        {\n          \"passage\": \"When an industry treats a nursing strike as a revenue line item, perhaps the system is working exact\",\n          \"location\": \"paragraph 1 (opening)\",\n          \"signal\": \"Hook detected (type: question)\",\n          \"severity\": \"info\"\n        },\n        {\n          \"passage\": \"5 middle paragraphs\",\n          \"location\": \"paragraphs 2-6\",\n          \"signal\": \"Development present\",\n          \"severity\": \"info\"\n        },\n        {\n          \"passage\": \"The facilities that have done the work are not going back. The model was never b\",\n          \"