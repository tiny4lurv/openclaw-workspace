{"type":"message","id":"b4878243","parentId":"202a05c5","timestamp":"2026-04-07T21:47:48.463Z","message":{"role":"toolResult","toolCallId":"ollama_call_f49190ac-759b-4539-a0da-78aa779a139f","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nTinyQE: Tiny Quality Evaluator\nMain entry point.\n\"\"\"\nimport sys\nimport os\nimport json\nimport importlib.util\nfrom typing import Dict, Any, List\n\n# Add project root to path for imports\nsys.path.insert(0, os.path.dirname(__file__))\n\ndef import_analyzer(dimension_id: str):\n    \"\"\"\n    Dynamically imports an analyzer module.\n    Mapping: dimension_id -> analyzer filename\n    \"\"\"\n    # Map dimension IDs to analyzer filenames\n    ANALYZER_MAP = {\n        \"A1\": \"linguistic_integrity\",\n        \"A2\": \"readability\",\n        \"B1\": \"thesis_clarity\",\n        \"B2\": \"logical_flow\",\n        \"B3\": \"structural_completeness\",\n        \"C1\": \"evidence_quality\",\n        \"C2\": \"argumentative_rigor\",\n        \"C3\": \"proportionality\",\n        \"D1\": \"authorial_voice\",\n        \"D2\": \"tone_consistency\",\n        \"D3\": \"emotional_calibration\",\n        \"E1\": \"platform_reach\",\n        \"E2\": \"authenticity_signal\",\n        \"E3\": \"closing_strength\"\n    }\n\n    analyzer_name = ANALYZER_MAP.get(dimension_id)\n    if not analyzer_name:\n        raise ValueError(f\"No analyzer mapped for dimension {dimension_id}\")\n\n    # Construct path\n    analyzer_path = os.path.join(\n        os.path.dirname(__file__),\n        \"analyzers\",\n        f\"{analyzer_name}.py\"\n    )\n\n    if not os.path.exists(analyzer_path):\n        raise FileNotFoundError(f\"Analyzer not found: {analyzer_path}\")\n\n    # Import the module\n    spec = importlib.util.spec_from_file_location(analyzer_name, analyzer_path)\n    module = importlib.util.module_from_spec(spec)\n    sys.modules[analyzer_name] = module\n    spec.loader.exec_module(module)\n    return module\n\ndef run_analyzer(dimension_id: str, text: str, format_label: str, format_profile: Dict = None) -> Dict[str, Any]:\n    \"\"\"\n    Runs a single analyzer and returns its result.\n    \"\"\"\n    try:\n        module = import_analyzer(dimension_id)\n        # Assume each analyzer has an analyze(text, format_hint, format_profile) function\n        if hasattr(module, 'analyze'):\n            return module.analyze(text, format_hint=format_label, format_profile=format_profile)\n        else:\n            # Fallback: look for a function named after the dimension\n            func_name = f\"analyze_{dimension_id.lower()}\"\n            if hasattr(module, func_name):\n                func = getattr(module, func_name)\n                return func(text, format_hint=format_label, format_profile=format_profile)\n            else:\n                raise AttributeError(f\"Analyzer {dimension_id} has no 'analyze' function\")\n    except Exception as e:\n        # Return a safe error result so the pipeline doesn't crash\n        return {\n            \"dimension\": dimension_id,\n            \"dimension_name\": dimension_id,  # Will be filled in by mapper if possible\n            \"score\": 0.0,\n            \"verdict\": \"fail\",\n            \"confidence\": 0.0,\n            \"evidence\": [{\n                \"passage\": str(e),\n                \"location\": \"analyzer_error\",\n                \"signal\": f\"Analyzer failed: {type(e).__name__}\",\n                \"severity\": \"error\"\n            }],\n            \"interpretation\": f\"Analyzer {dimension_id} failed to run.\",\n            \"recommendation\": \"Check analyzer implementation and dependencies.\"\n        }\n\ndef evaluate(text: str, output_format: str = \"narrative\") -> Dict[str, Any]:\n    \"\"\"\n    Main evaluation pipeline.\n    1. Detect format\n    2. Load format profile\n    3. Run all 12 analyzers in parallel (sequential for now)\n    4. Aggregate scores\n    5. Format output\n    \"\"\"\n    # Import core modules\n    sys.path.insert(0, os.path.join(os.path.dirname(__file__), \"core\"))\n    from format_detector import detect_format, load_format_profile\n    from aggregator import apply_weights\n    from formatter import format_output\n\n    # Step 1: Detect format\n    format_label, format_confidence = detect_format(text)\n    format_profile = load_format_profile(format_label)\n\n    # Step 2: Define all dimensions we want to evaluate\n    # We'll start with Phase 1 + B2 + B3 + C1 + C2 + C3 + D1 + D2 + D3 for now; others will return not-implemented\n    DIMENSIONS = [\"A1\", \"A2\", \"B1\", \"B2\", \"B3\", \"C1\", \"C2\", \"C3\", \"D1\", \"D2\", \"D3\", \"E1\"]  # Phase 1 + Logical Flow + Structural Completeness + Evidence Quality + Argumentative Rigor + Proportionality + Authorial Voice + Tone Consistency + Emotional Calibration\n    # Full list for future: [\"A1\", \"A2\", \"B1\", \"B2\", \"B3\", \"C1\", \"C2\", \"C3\", \"D1\", \"D2\", \"D3\", \"E1\", \"E2\", \"E3\"]\n\n    # Step 3: Run analyzers\n    dimension_results = []\n    uncertain_flags = []  # Collect low-confidence flags from analyzers\n\n    for dim in DIMENSIONS:\n        result = run_analyzer(dim, text, format_label, format_profile)\n        dimension_results.append(result)\n\n        # Check if analyzer flagged low confidence\n        if result.get(\"confidence\", 1.0) < 0.6:\n            uncertain_flags.append({\n                \"dimension\": dim,\n                \"dimension_name\": result.get(\"dimension_name\", dim),\n                \"confidence\": result.get(\"confidence\", 0.0),\n                \"flag\": result.get(\"interpretation\", \"Low confidence in evaluation\"),\n                \"evidence\": result.get(\"evidence\", [])\n            })\n\n    # Step 4: Aggregate\n    weighted_score, priority_queue = apply_weights(dimension_results, format_profile)\n\n    # Step 5: Format output\n    output = format_output(\n        dimension_results,\n        weighted_score,\n        priority_queue,\n        format_label,\n        format_confidence,\n        uncertain_flags,\n        output_format=output_format\n    )\n\n    return output\n\ndef main():\n    \"\"\"CLI entry point.\"\"\"\n    import argparse\n\n    parser = argparse.ArgumentParser(description=\"TinyQE: Tiny Quality Evaluator\")\n    parser.add_argument(\n        \"text\",\n        nargs=\"?\",\n        help=\"Text to evaluate. If not provided, reads from stdin.\"\n    )\n    parser.add_argument(\n        \"--format\",\n        choices=[\"json\", \"narrative\"],\n        default=\"narrative\",\n        help=\"Output format\"\n    )\n    parser.add_argument(\n        \"--dimensions\",\n        nargs=\"+\",\n        help=\"Specific dimensions to run (e.g., A1 A2 B1). Default: all available.\"\n    )\n    args = parser.parse_args()\n\n    # Get text\n    if args.text:\n        text = args.text\n    else:\n        text = sys.stdin.read().strip()\n\n    if not text:\n        print(\"Error: No text provided\", file=sys.stderr)\n        sys.exit(1)\n\n    # Run evaluation\n    result = evaluate(text, output_format=args.format)\n\n    # Output\n    if args.format == \"json\":\n        print(json.dumps(result, indent=2))\n    else:\n        print(result[\"content\"])\n\nif __name__ == \"__main__\":\n    main()"}],"isError":false,"timestamp":1775598468428}}
{"type":"message","id":"f32f8fa7","parentId":"b4878243","timestamp":"2026-04-07T21:48:52.880Z","message":{"role":"assistant","content":[{"type":"text","text":"I have the full picture. Here's what needs to change and why:\n\n**Thesis Clarity (B1):** The tool sees first paragraph + last paragraph as competing \"theses.\" For LinkedIn, the last paragraph is a landing/CTA — not a thesis. It has no logic to distinguish them.\n\n**Structural Completeness (B3):** It tries to detect hooks but your opening (\"When an industry treats a nursing strike as a revenue line item\") doesn't match any of its patterns — no question, no number, no \"how to,\" no \"secret.\" It misses observational/teaser hooks entirely.\n\n**Proportionality (C3):** It classifies \"the model is working exactly as designed\" as an extraordinary claim and finds no \"strong evidence\" to match — then fails. For social media, this bar is wrong. The fix isn't just recalibration — it's telling the tool what counts as extraordinary in a social media context.\n\nThe model I use to write the Python doesn't matter — these are logic changes, not prompt engineering. Let me build them now.\n"},{"type":"toolCall","id":"ollama_call_10b93b1c-1df2-43a1-a200-77a64d5292f9","name":"write","arguments":{"path":"/home/tiny4lurv/.openclaw/workspace/tinyqe/analyzers/thesis_clarity.py","content":"#!/usr/bin/env python3\n\"\"\"\nThesis Clarity Analyzer (B1)\nDetects presence and strength of central claim.\nFor LinkedIn/X (short-form): the opening line is the hook/thesis combined.\nThe last paragraph is the landing, not a thesis candidate.\nFor blog/essay (long-form): traditional thesis detection.\n\nFormat-aware: uses format to determine what counts as a \"thesis.\"\n\"\"\"\nimport re\nimport json\nimport sys\nfrom typing import Dict, Any, List, Tuple\n\ndef detect_format_shortform(text: str) -> bool:\n    \"\"\"Heuristic: if text is under 2500 chars and has paragraph structure, treat as short-form.\"\"\"\n    return len(text.strip()) < 2500\n\ndef extract_sentences(paragraph: str) -> List[str]:\n    \"\"\"Split paragraph into sentences.\"\"\"\n    sentences = re.split(r'[.!?]+', paragraph)\n    return [s.strip() for s in sentences if s.strip()]\n\ndef is_hook_pattern(sentence: str) -> bool:\n    \"\"\"\n    Recognise LinkedIn/X hook patterns.\n    Hooks are teaser/statement patterns that create curiosity without stating the full argument.\n    NOT thesis statements — they don't make the claim, they name the phenomenon.\n    \"\"\"\n    s = sentence.lower()\n    # Observational/teaser hooks — imply a phenomenon, create curiosity\n    observational = [\n        'when an industry', 'what happens when', 'here\\'s the thing',\n        'the problem isn\\'t', 'here\\'s what', 'this is why', 'what if i told you',\n        'the truth about', 'let me explain', 'here\\'s why', 'what nobody tells you',\n        'the real problem', 'the hidden cost', 'the unspoken', 'the secret',\n        'turns out', 'it turns out', 'surprising', 'interestingly', 'curiously',\n        'remarkably', 'the fact is', 'the reality is', 'the inconvenient truth'\n    ]\n    # Questions (not answers)\n    if sentence.strip().endswith('?') and '?' in sentence:\n        return True\n    if any(phrase in s for phrase in observational):\n        return True\n    return False\n\ndef is_landing_pattern(sentence: str, all_sentences: List[str]) -> bool:\n    \"\"\"\n    Recognise landing/CTA patterns — these are NOT thesis candidates.\n    \"\"\"\n    s = sentence.lower()\n    landing_phrases = [\n        'that\\'s why we', 'this is why we', 'learn more', 'sign up', 'get started',\n        'save this', 'book a', 'download', 'try free', 'start free', 'free trial',\n        'click below', 'comment', 'share your', 'questions', 'interested in',\n        'if you want', 'reach out', 'let me know', 'connect with',\n        'ready to', 'the facilities that have done the work',\n        'the model was never built', 'the question for', 'ask yourself'\n    ]\n    if any(phrase in s for phrase in landing_phrases):\n        return True\n    # Short final sentences that are directives\n    words = len(sentence.split())\n    if words <= 8 and all_sentences and sentence == all_sentences[-1]:\n        return True\n    return False\n\ndef extract_thesis_candidates(paragraph: str, is_shortform: bool = False) -> List[str]:\n    \"\"\"\n    Extract potential thesis/claim sentences from a paragraph.\n    For short-form: exclude hook patterns and landing patterns.\n    For long-form: all declarative sentences are candidates.\n    \"\"\"\n    sentences = extract_sentences(paragraph)\n    candidates = []\n\n    for sent in sentences:\n        if len(sent.split()) < 4:\n            continue\n        # Skip hooks in short-form\n        if is_shortform and is_hook_pattern(sent):\n            continue\n        # Skip landings\n        if is_shortform and is_landing_pattern(sent, sentences):\n            continue\n        # Look for declarative/claim-like sentences\n        lower_sent = sent.lower()\n        claim_indicators = [\n            'is', 'are', 'will', 'must', 'should', 'can', 'cannot',\n            'leads to', 'results in', 'shows', 'demonstrates', 'proves',\n            'the', 'this', 'these', 'those'\n        ]\n        if any(word in lower_sent for word in claim_indicators):\n            if not sent.strip().endswith('?'):\n                candidates.append(sent)\n    return candidates[:3]  # Return top 3 candidates\n\ndef is_vague_thesis(thesis: str) -> bool:\n    \"\"\"Check if thesis is too vague or uncertain to be a strong thesis.\"\"\"\n    vague = ['it depends', 'maybe', 'perhaps', 'could be', 'might be', 'sometimes', 'we\\'ll see']\n    return any(v in thesis.lower() for v in vague)\n\ndef explain_thesis_conflict(candidates: List[str], paragraphs: List[str], text: str) -> str:\n    \"\"\"\n    Produce a human-readable explanation of why multiple theses were detected.\n    Returns the explanation string.\n    \"\"\"\n    if len(candidates) <= 1:\n        return \"\"\n\n    explanations = []\n    for i, cand in enumerate(candidates):\n        # Find which paragraph this candidate came from\n        for pi, para in enumerate(paragraphs):\n            if cand in para:\n                position = \"first\" if pi == 0 else (\"last\" if pi == len(paragraphs) - 1 else f\"paragraph {pi+1}\")\n                explanations.append(f\"Candidate {i+1} (from {position}): '{cand[:80]}...'\")\n                break\n\n    return \" || \".join(explanations)\n\ndef analyze(text: str, format_hint: str = \"generic\", format_profile: Dict = None) -> Dict[str, Any]:\n    \"\"\"\n    Main entry point.\n    Returns score 0.0-1.0 where 1.0 = clear, single, defensible thesis.\n    Format-aware: short-form (LinkedIn/X) treats hook as thesis, long-form (blog) uses traditional detection.\n    \"\"\"\n    if not text.strip():\n        return {\n            \"dimension\": \"B1\",\n            \"dimension_name\": \"Thesis Clarity\",\n            \"score\": 0.0,\n            \"verdict\": \"fail\",\n            \"confidence\": 0.9,\n            \"evidence\": [{\"passage\": \"\", \"location\": \"document\", \"signal\": \"No text provided\", \"severity\": \"error\"}],\n            \"interpretation\": \"Empty text.\",\n            \"recommendation\": \"Provide content to evaluate.\"\n        }\n\n    # Determine if short-form or long-form\n    is_shortform = detect_format_shortform(text) or format_hint in [\"linkedin\", \"x_thread\", \"copywriting\"]\n\n    # Split into paragraphs\n    paragraphs = re.split(r'\\n\\s*\\n', text.strip())\n    paragraphs = [p.strip() for p in paragraphs if p.strip()]\n\n    if not paragraphs:\n        return {\n            \"dimension\": \"B1\",\n            \"dimension_name\": \"Thesis Clarity\",\n            \"score\": 0.0,\n            \"verdict\": \"fail\",\n            \"confidence\": 0.9,\n            \"evidence\": [{\"passage\": \"\", \"location\": \"document\", \"signal\": \"No paragraphs found\", \"severity\": \"error\"}],\n            \"interpretation\": \"No discernible structure.\",\n            \"recommendation\": \"Organize content into paragraphs.\"\n        }\n\n    # For short-form: the FIRST paragraph is the hook+thesis combined\n    # We extract thesis candidates from the full text, but weight first paragraph heavily\n    all_candidates = []\n    for pi, para in enumerate(paragraphs):\n        is_first = (pi == 0)\n        is_last = (pi == len(paragraphs) - 1)\n\n        # In short-form, last paragraph is always the landing — skip it for thesis detection\n        if is_shortform and is_last:\n            continue\n\n        candidates = extract_thesis_candidates(para, is_shortform=is_shortform)\n        for c in candidates:\n            all_candidates.append({\n                \"text\": c,\n                \"paragraph\": pi,\n                \"is_first\": is_first,\n                \"weight\": 2.0 if is_first else 1.0  # First paragraph candidates weighted higher\n            })\n\n    # Deduplicate\n    seen = set()\n    unique_candidates = []\n    for c in all_candidates:\n        key = c[\"text\"][:50].lower()\n        if key not in seen:\n            seen.add(key)\n            unique_candidates.append(c)\n\n    # Score\n    score = 1.0\n    issues = []\n    thesis_explanation = \"\"\n\n    if len(unique_candidates) == 0:\n        score = 0.3  # Partial credit: post may be purely narrative/hook-driven\n        issues.append((\"no_thesis\", \"No clear thesis-like statement detected (hook-only structure may be intentional)\"))\n    elif len(unique_candidates) == 1:\n        thesis = unique_candidates[0][\"text\"]\n        if is_vague_thesis(thesis):\n            score = 0.6\n            issues.append((\"vague_thesis\", f\"Thesis may be too vague: '{thesis[:60]}...'\"))\n        else:\n            score = 0.9  # Good\n    else:\n        # Multiple candidates — explain WHY\n        thesis_explanation = explain_thesis_conflict(\n            [c[\"text\"] for c in unique_candidates],\n            paragraphs,\n            text\n        )\n        score = 0.5\n        issues.append((\"multiple_theses\", f\"Found {len(unique_candidates)} potential thesis-like statements\"))\n\n    # Check if thesis is addressed in conclusion (for long-form only)\n    if not is_shortform and len(unique_candidates) > 0 and len(paragraphs) > 2:\n        thesis = unique_candidates[0][\"text\"]\n        conclusion = paragraphs[-1].lower()\n        thesis_words = set(re.findall(r'\\b\\w{4,}\\b', thesis.lower()))\n        conclusion_words = set(re.findall(r'\\b\\w{4,}\\b', conclusion))\n        overlap = len(thesis_words & conclusion_words)\n        if overlap < 2:\n            score = min(score, 0.7)\n            issues.append((\"thesis_not_resolved\", \"Thesis may not be resolved by conclusion\"))\n\n    score = max(0.0, min(1.0, score))\n\n    # Verdict\n    if score >= 0.8:\n        verdict = \"pass\"\n    elif score >= 0.5:\n        verdict = \"warning\"\n    else:\n        verdict = \"fail\"\n\n    confidence = 0.85 if is_shortform else 0.8\n\n    # Evidence\n    evidence = []\n    if unique_candidates:\n        primary = unique_candidates[0]\n        evidence.append({\n            \"passage\": primary[\"text\"][:200],\n            \"location\": f\"paragraph {primary['paragraph']+1}\" + (\" (opening)\" if primary[\"is_first\"] else \"\"),\n            \"signal\": f\"Primary thesis candidate: '{primary['text'][:100]}...'\",\n            \"severity\": \"info\"\n        })\n        if len(unique_candidates) > 1:\n            # Only report secondary candidates as warnings if they're in the BODY, not the landing\n            body_candidates = [c for c in unique_candidates[1:] if c[\"paragraph\"] > 0 and c[\"paragraph\"] < len(paragraphs) - 1]\n            if body_candidates:\n                evidence.append({\n                    \"passage\": unique_candidates[1][\"text\"][:200],\n                    \"location\": f\"paragraph {unique_candidates[1]['paragraph']+1}\",\n                    \"signal\": f\"Secondary thesis candidate: '{unique_candidates[1]['text'][:80]}...'\",\n                    \"severity\": \"warning\"\n                })\n            # If thesis_explanation exists, include it\n            if thesis_explanation:\n                evidence.append({\n                    \"passage\": thesis_explanation,\n                    \"location\": \"document\",\n                    \"signal\": \"thesis_conflict_explanation\",\n                    \"severity\": \"info\"\n                })\n    else:\n        evidence.append({\n            \"passage\": paragraphs[0][:200] if paragraphs else \"\",\n            \"location\": \"first_paragraph\",\n            \"signal\": \"No thesis-like statement detected — hook-only structure\",\n            \"severity\": \"info\"\n        })\n\n    # Interpretation and recommendation\n    if verdict == \"pass\":\n        interpretation = \"Clear thesis detected.\"\n        recommendation = \"Thesis is strong and clear.\"\n    elif verdict == \"warning\":\n        if len(unique_candidates) == 1:\n            interpretation = \"Thesis present but may need sharpening.\"\n            recommendation = \"Ensure thesis is specific, defensible, and addressed throughout.\"\n        else:\n            interpretation = \"Multiple thesis-like statements detected. This may be intentional for the format.\"\n            recommendation = \"For short-form (LinkedIn/X): the opening line is the hook+thesis combined. Body paragraphs develop it, they don't introduce new theses. For long-form: choose one central claim and ensure all content supports it.\"\n    else:\n        interpretation = \"No clear thesis detected.\"\n        recommendation = \"State your central claim clearly in the opening.\"\n\n    return {\n        \"dimension\": \"B1\",\n        \"dimension_name\": \"Thesis Clarity\",\n        \"score\": round(score, 3),\n        \"verdict\": verdict,\n        \"confidence\": confidence,\n        \"evidence\": evidence,\n        \"interpretation\": interpretation,\n        \"recommendation\": recommendation\n    }\n\nif __name__ == \"__main__\":\n    if len(sys.argv) > 1:\n        text = \" \".join(sys.argv[1:])\n    else:\n        text = sys.stdin.read().strip()\n    import os, json as json_mod\n    profile_path = os.path.join(os.path.dirname(__file__), \"..\", \"config\", \"format_profiles\", \"linkedin.json\")\n    try:\n        with open(profile_path, 'r') as f:\n            profile = json_mod.load(f)\n    except:\n        profile = None\n    result = analyze(text, format_hint=\"linkedin\", format_profile=profile)\n    print(json.dumps(result, indent=2))\n"}}],"stopReason":"toolUse","api":"ollama","provider":"ollama","model":"minimax-m2.7:cloud","usage":{"input":68150,"output":3660,"cacheRead":0,"cacheWrite":0,"totalTokens":71810,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"timestamp":1775598532870}}
