{"type":"message","id":"24956ace","parentId":"fcee3c6b","timestamp":"2026-04-07T21:52:20.496Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"ollama_call_15f093c2-5493-4f64-bbbe-147adaae4458","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\nStructural Completeness Analyzer (B3)\nChecks whether the argument has all necessary components:\nclaim → setup → evidence → complication → resolution (blog)\nhook → development → landing (short-form: LinkedIn, X, copywriting)\n\nSHORT-FORM HOOK RECOGNITION:\nA hook is NOT a thesis statement. A hook names a phenomenon or asks a question\nthat makes the reader want to know more — without giving away the argument.\nTypes that score a hook:\n  - Questions (rhetorical or genuine)\n  - Surprising statements / statistics\n  - Bold observational claims (creates curiosity)\n  - \"When X happens, [something unexpected]\" patterns\n  - Contradiction patterns (\"The industry celebrates X\")\n  - Pattern interruption (\"The thing nobody tells you about X\")\n\"\"\"\nimport re\nimport json\nimport sys\nimport os\nfrom typing import Dict, Any, List, Tuple\n\n# ─── Hook detection patterns for short-form ────────────────────────────────────\nHOOK_PATTERNS = {\n    \"question\": [r'\\?$', r'^what\\s+', r'^why\\s+', r'^how\\s+', r'^when\\s+', r'^if\\s+'],\n    \"observational_teaser\": [\n        r\"^when an industry\", r\"^what happens when\", r\"^here('s| is) the thing\",\n        r\"^what nobody\", r\"^the real\", r\"^the hidden\", r\"^the unspoken\",\n        r\"^the inconvenient\", r\"^what i learned\", r\"^what they don't\",\n        r\"^the secret\", r\"^the problem with\", r\"^the truth about\",\n        r\"^turns out\", r\"^it turns out\", r\"^surprising\", r\"^curiously\",\n        r\"^remarkably\", r\"^interestingly\", r\"^the fact is\",\n        r\"^the reality is\", r\"^the problem isn('t| not)\"\n    ],\n    \"contradiction\": [\n        r\"^while\\b\", r\"^although\\b\", r\"^but\\b\", r\"^yet\\b\",\n        r\"^they said\", r\"^the industry (celebrates|calls|calls it)\",\n        r\"^it('s| is) not.*but\", r\"^this.*isn('t| not) what\"\n    ],\n    \"stat_start\": [\n        r'^\\$[\\d,]+', r'^\\d+%', r'^\\d+\\s+(million|billion|thousand)',\n        r'^\\$\\d+\\s+million', r'^in\\s+\\d{4}', r'^in\\s+20\\d{2}'\n    ],\n    \"bold_claim\": [\n        r\"^the only\", r\"^never again\", r\"^no one\", r\"^everyone is\",\n        r\"^stop\\b\", r\"^never\\b\", r\"^always\\b\", r\"^you('re| are) not\",\n        r\"^this is (why|how|the)\", r\"^here('s| is) (why|what|how)\"\n    ]\n}\n\n\ndef detect_hook(paragraph: str) -> Tuple[bool, str, str]:\n    \"\"\"\n    Returns (is_hook: bool, hook_type: str, evidence: str)\n    \"\"\"\n    first_line = paragraph.strip().split('\\n')[0]\n    first_lower = first_line.lower()\n\n    for hook_type, patterns in HOOK_PATTERNS.items():\n        for pattern in patterns:\n            if re.search(pattern, first_lower):\n                return (True, hook_type, first_line[:100])\n\n    words = len(first_line.split())\n    if words <= 20 and not first_line.endswith('.') and not first_line.endswith(':'):\n        return (True, \"minimal_curiosity\", first_line[:100])\n\n    return (False, \"\", \"\")\n\n\ndef get_format(text: str) -> str:\n    \"\"\"Detect format.\"\"\"\n    try:\n        sys.path.insert(0, os.path.join(os.path.dirname(__file__), \"..\", \"core\"))\n        from format_detector import detect_format\n        fmt, _ = detect_format(text)\n        return fmt\n    except Exception:\n        return \"generic\"\n\n\ndef analyze(text: str, format_hint: str = \"generic\", format_profile: Dict = None) -> Dict[str, Any]:\n    \"\"\"\n    Main entry point.\n    LinkedIn/X: hook → development → landing.\n    Blog/essay: claim → setup → evidence → complication → resolution.\n    \"\"\"\n    if not text.strip():\n        return {\n            \"dimension\": \"B3\",\n            \"dimension_name\": \"Structural Completeness\",\n            \"score\": 0.0,\n            \"verdict\": \"fail\",\n            \"confidence\": 0.9,\n            \"evidence\": [{\"passage\": \"\", \"location\": \"document\", \"signal\": \"No text provided\", \"severity\": \"error\"}],\n            \"interpretation\": \"Empty text.\",\n            \"recommendation\": \"Provide content to evaluate.\"\n        }\n\n    fmt = get_format(text)\n    if format_hint and format_hint != \"generic\":\n        fmt = format_hint\n\n    paragraphs = re.split(r'\\n\\s*\\n', text.strip())\n    paragraphs = [p.strip() for p in paragraphs if p.strip()]\n\n    if not paragraphs:\n        return {\n            \"dimension\": \"B3\",\n            \"dimension_name\": \"Structural Completeness\",\n            \"score\": 0.0,\n            \"verdict\": \"fail\",\n            \"confidence\": 0.9,\n            \"evidence\": [{\"passage\": \"\", \"location\": \"document\", \"signal\": \"No paragraphs found\", \"severity\": \"error\"}],\n            \"interpretation\": \"No discernible structure.\",\n            \"recommendation\": \"Organize content into paragraphs.\"\n        }\n\n    found = {k: False for k in [\"hook\", \"claim\", \"setup\", \"evidence\", \"complication\", \"resolution\", \"development\", \"landing\"]}\n    evidence = []\n\n    # ── SHORT-FORM ──────────────────────────────────────────────────────────────\n    if fmt in [\"linkedin\", \"x_thread\", \"copywriting\"]:\n\n        # HOOK: first paragraph\n        is_hook, hook_type, hook_text = detect_hook(paragraphs[0])\n        if is_hook:\n            found[\"hook\"] = True\n            evidence.append({\n                \"passage\": hook_text,\n                \"location\": \"paragraph 1 (opening)\",\n                \"signal\": f\"Hook detected (type: {hook_type})\",\n                \"severity\": \"info\"\n            })\n        else:\n            if len(paragraphs[0].split()) <= 25:\n                found[\"hook\"] = True\n                evidence.append({\n                    \"passage\": paragraphs[0][:80],\n                    \"location\": \"paragraph 1 (opening)\",\n                    \"signal\": \"Possible minimal hook (short opening line)\",\n                    \"severity\": \"info\"\n                })\n            else:\n                evidence.append({\n                    \"passage\": paragraphs[0][:80],\n                    \"location\": \"paragraph 1\",\n                    \"signal\": \"Hook not clearly detected\",\n                    \"severity\": \"warning\"\n                })\n\n        # DEVELOPMENT: middle paragraphs\n        if len(paragraphs) >= 2:\n            found[\"development\"] = True\n            evidence.append({\n                \"passage\": f\"{len(paragraphs)-2} middle paragraphs\",\n                \"location\": f\"paragraphs 2-{len(paragraphs)-1}\",\n                \"signal\": \"Development present\",\n                \"severity\": \"info\"\n            })\n\n        # LANDING: last paragraph\n        last = paragraphs[-1].lower()\n        landing_phrases = [\n            \"that's why\", \"this is why\", \"learn more\", \"sign up\", \"get started\",\n            \"save this\", \"book a\", \"download\", \"try free\", \"start free\", \"free trial\",\n            \"click below\", \"comment\", \"share your\", \"questions\",\n            \"if you want\", \"reach out\", \"let me know\", \"connect with\",\n            \"ready to\", \"the facilities that have done\",\n            \"the model was never built\", \"the question for\", \"ask yourself\",\n            \"what is your\", \"what's your\"\n        ]\n        is_short_final = len(paragraphs[-1].split()) <= 10\n\n        if any(phrase in last for phrase in landing_phrases) or is_short_final:\n            found[\"landing\"] = True\n            evidence.append({\n                \"passage\": paragraphs[-1][:80],\n                \"location\": f\"paragraph {len(paragraphs)} (closing)\",\n                \"signal\": \"Landing detected\",\n                \"severity\": \"info\"\n            })\n        elif paragraphs[-1].strip().endswith('.') and len(paragraphs[-1].split()) >= 5:\n            found[\"landing\"] = True\n            evidence.append({\n                \"passage\": paragraphs[-1][:80],\n                \"location\": f\"paragraph {len(paragraphs)} (closing)\",\n                \"signal\": \"Landing/close detected\",\n                \"severity\": \"info\"\n            })\n        else:\n            evidence.append({\n                \"passage\": paragraphs[-1][:80],\n                \"location\": f\"paragraph {len(paragraphs)}\",\n                \"signal\": \"Landing not clearly detected\",\n                \"severity\": \"warning\"\n            })\n\n        required = [\"hook\", \"development\", \"landing\"]\n        missing = [r for r in required if not found[r]]\n\n    # ── LONG-FORM ─────────────────────────────────────────────────────────────\n    else:\n        full_text = ' '.join(paragraphs).lower()\n\n        claim_patterns = [\n            r'\\bis\\b', r'\\bare\\b', r'\\bwill\\b', r'\\bmust\\b', r'\\bshould\\b',\n            r'\\bcauses\\b', r'\\bleads to\\b', r'\\bshows that\\b',\n            r'\\bdemonstrates that\\b', r'\\bevidence suggests\\b', r'\\bstudy indicates\\b'\n        ]\n        for para in paragraphs[:2]:\n            for sent in re.split(r'[.!?]+', para):\n                if any(re.search(p, sent.lower()) for p in claim_patterns):\n                    found[\"claim\"] = True\n                    evidence.append({\"passage\": sent.strip()[:100], \"location\": \"early paragraphs\", \"signal\": \"Claim detected\", \"severity\": \"info\"})\n                    break\n            if found[\"claim\"]:\n                break\n\n        setup_indicators = [\n            r'background', r'context', r'problem', r'challenge', r'issue',\n            r'situation', r'currently', r'today', r'in recent years',\n            r'according to', r'data shows', r'historically'\n        ]\n        if any(re.search(p, full_text) for p in setup_indicators):\n            found[\"setup\"] = True\n            evidence.append({\"passage\": \"Context or background detected\", \"location\": \"document\", \"signal\": \"Setup detected\", \"severity\": \"info\"})\n\n        evidence_indicators = [\n            r'\\d+%', r'\\d+\\.\\d+', r'according to', r'study', r'research',\n            r'data shows', r'p <', r'correlation', r'example', r'for instance',\n            r'case study', r'citation', r'reference', r'\\$[\\d,]+', r'\\$[\\d,]+ million'\n        ]\n        if any(re.search(p, full_text, re.IGNORECASE) for p in evidence_indicators):\n            found[\"evidence\"] = True\n            evidence.append({\"passage\": \"Data, examples, or citations detected\", \"location\": \"document\", \"signal\": \"Evidence detected\", \"severity\": \"info\"})\n\n        complication_indicators = [\n            r'however', r'but', r'although', r'despite', r'yet', r'still',\n            r'nevertheless', r'despite this', r'on the other hand',\n            r'limitations', r'challenges remain', r'obstacles', r'drawbacks'\n        ]\n        if any(re.search(p, full_text) for p in complication_indicators):\n            found[\"complication\"] = True\n            evidence.append({\"passage\": \"Counterargument or complication detected\", \"location\": \"document\", \"signal\": \"Complication detected\", \"severity\": \"info\"})\n\n        resolution_indicators = [\n            r'therefore', r'thus', r'hence', r'as a result', r'in conclusion',\n            r'to summarize', r'we recommend', r'solution', r'resolve',\n            r'address', r'overcome', r'mitigate', r'future work', r'next steps'\n        ]\n        if any(re.search(p, full_text) for p in resolution_indicators):\n            found[\"resolution\"] = True\n            evidence.append({\"passage\": \"Resolution or conclusion detected\", \"location\": \"document\", \"signal\": \"Resolution detected\", \"severity\": \"info\"})\n\n        required = [\"claim\", \"evidence\", \"resolution\"]\n        missing = [r for r in required if not found[r]]\n\n    # ── SCORE ─────────────────────────────────────────────────────────────────\n    found_required = sum(1 for r in required if found[r])\n    score = found_required / len(required) if required else 0.0\n    score = round(score, 3)\n\n    if score >= 0.8:\n        verdict = \"pass\"\n    elif score >= 0.5:\n        verdict = \"warning\"\n    else:\n        verdict = \"fail\"\n\n    confidence = 0.8\n\n    if not evidence:\n        evidence.append({\n            \"passage\": text[:100],\n            \"location\": \"document\",\n            \"signal\": \"No structural components clearly detected\",\n            \"severity\": \"warning\"\n        })\n\n    fmt_label = \"LinkedIn/X\" if fmt in [\"linkedin\", \"x_thread\", \"copywriting\"] else \"blog/essay\"\n\n    if verdict == \"pass\":\n        interpretation = f\"[{fmt_label}] Structure complete: {', '.join([r.upper() for r in required if found[r]])}.\"\n        recommendation = \"Structure is sound.\"\n    elif verdict == \"warning\":\n        missing_str = ', '.join([m.upper() for m in missing])\n        interpretation = f\"[{fmt_label}] Missing: {missing_str}.\"\n        if fmt in [\"linkedin\", \"x_thread\", \"copywriting\"]:\n            recommendation = \"Ensure your post has a hook (attention-grabber), development (elaboration), and landing (resolution/CTA).\"\n        else:\n            recommendation = \"Ensure your argument includes a clear claim, supporting evidence, and a resolution.\"\n    else:\n        missing_str = ', '.join([m.upper() for m in missing])\n        interpretation = f\"[{fmt_label}] Structure incomplete. Missing: {missing_str}.\"\n        if fmt in [\"linkedin\", \"x_thread\", \"copywriting\"]:\n            recommendation = \"Add a clear hook, develop your point in middle paragraphs, and end with a landing.\"\n        else:\n            recommendation = \"Restructure to include: claim → setup → evidence → resolution.\"\n\n    return {\n        \"dimension\": \"B3\",\n        \"dimension_name\": \"Structural Completeness\",\n        \"score\": score,\n        \"verdict\": verdict,\n        \"confidence\": confidence,\n        \"evidence\": evidence,\n        \"interpretation\": interpretation,\n        \"recommendation\": recommendation\n    }\n\n\nif __name__ == \"__main__\":\n    if len(sys.argv) > 1:\n        text = \" \".join(sys.argv[1:])\n    else:\n        text = sys.stdin.read().strip()\n    result = analyze(text)\n    print(json.dumps(result, indent=2))\n","path":"/home/tiny4lurv/.openclaw/workspace/tinyqe/analyzers/structural_completeness.py"}}],"stopReason":"toolUse","api":"ollama","provider":"ollama","model":"minimax-m2.7:cloud","usage":{"input":72728,"output":3413,"cacheRead":0,"cacheWrite":0,"totalTokens":76141,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"timestamp":1775598740495}}
