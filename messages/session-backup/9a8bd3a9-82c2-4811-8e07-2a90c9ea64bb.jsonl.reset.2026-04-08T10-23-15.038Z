n/home/tiny4lurv/.openclaw/workspace/tinyqe/analyzers/structural_completeness.py\n/home/tiny4lurv/.openclaw/workspace/tinyqe/analyzers/thesis_clarity.py\n/home/tiny4lurv/.openclaw/workspace/tinyqe/analyzers/tone_consistency.py\n/home/tiny4lurv/.openclaw/workspace/tinyqe/config/format_profiles/blog.json\n/home/tiny4lurv/.openclaw/workspace/tinyqe/config/format_profiles/linkedin.json\n/home/tiny4lurv/.openclaw/workspace/tinyqe/core/__pycache__/aggregator.cpython-312.pyc\n/home/tiny4lurv/.openclaw/workspace/tinyqe/core/__pycache__/format_detector.cpython-312.pyc\n/home/tiny4lurv/.openclaw/workspace/tinyqe/core/__pycache__/formatter.cpython-312.pyc\n/home/tiny4lurv/.openclaw/workspace/tinyqe/core/aggregator.py\n/home/tiny4lurv/.openclaw/workspace/tinyqe/core/format_detector.py\n/home/tiny4lurv/.openclaw/workspace/tinyqe/core/formatter.py\n/home/tiny4lurv/.openclaw/workspace/tinyqe/glossaries/legal.txt\n/home/tiny4lurv/.openclaw/workspace/tinyqe/glossaries/medical.txt\n/home/tiny4lurv/.openclaw/workspace/tinyqe/glossaries/staffing.txt\n/home/tiny4lurv/.openclaw/workspace/tinyqe/research/ai_content_quality_evaluation_framework.txt\n/home/tiny4lurv/.openclaw/workspace/tinyqe/research/building_writing_quality_evaluation_tool.txt\n/home/tiny4lurv/.openclaw/workspace/tinyqe/research/deep-research-report.md\n/home/tiny4lurv/.openclaw/workspace/tinyqe/test_post.txt\n/home/tiny4lurv/.openclaw/workspace/tinyqe/test_post_improved.txt\n/home/tiny4lurv/.openclaw/workspace/tinyqe/test_post_strong.txt\n/home/tiny4lurv/.openclaw/workspace/tinyqe/tinyqe.py","cwd":"/home/tiny4lurv/.openclaw/workspace"},"isError":false,"timestamp":1775598433432}}
{"type":"message","id":"fcf20c57","parentId":"3332c9fb","timestamp":"2026-04-07T21:47:20.906Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"ollama_call_5bd4ade2-b27e-4699-9f3f-14191fee76fd","name":"read","arguments":{"path":"/home/tiny4lurv/.openclaw/workspace/tinyqe/analyzers/thesis_clarity.py"}}],"stopReason":"toolUse","api":"ollama","provider":"ollama","model":"minimax-m2.7:cloud","usage":{"input":58700,"output":222,"cacheRead":0,"cacheWrite":0,"totalTokens":58922,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"timestamp":1775598440905}}
{"type":"message","id":"7c5dfb39","parentId":"fcf20c57","timestamp":"2026-04-07T21:47:20.975Z","message":{"role":"toolResult","toolCallId":"ollama_call_5bd4ade2-b27e-4699-9f3f-14191fee76fd","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nThesis Clarity Analyzer (B1)\nDetects presence and strength of central claim.\nUses heuristic: first/last paragraph analysis + claim extraction.\n\"\"\"\nimport re\nimport json\nimport sys\nfrom typing import Dict, Any, List\n\ndef extract_claims_from_paragraph(paragraph: str) -> List[str]:\n    \"\"\"\n    Extract potential claim sentences from a paragraph.\n    Looks for: declarative sentences, sentences with modal verbs (should, must, will),\n    sentences with causal language (because, therefore, leads to).\n    \"\"\"\n    # Split into sentences\n    sentences = re.split(r'[.!?]+', paragraph)\n    sentences = [s.strip() for s in sentences if s.strip()]\n\n    claims = []\n    for sent in sentences:\n        # Skip very short sentences\n        if len(sent.split()) < 3:\n            continue\n        # Heuristics for claim-likeness\n        lower_sent = sent.lower()\n        # Contains assertive language\n        if any(word in lower_sent for word in ['is', 'are', 'will', 'must', 'should', 'can', 'cannot', 'leads to', 'results in', 'shows', 'demonstrates', 'proves']):\n            # Not a question\n            if not sent.strip().endswith('?'):\n                claims.append(sent)\n        # Or starts with a topic and makes a statement\n        elif re.match(r'^(the|this|these|those|a|an)\\s+\\w+', lower_sent) and len(sent.split()) > 5:\n            claims.append(sent)\n    return claims[:2]  # Return top 2 candidates per paragraph\n\ndef analyze(text: str, format_hint: str = \"generic\", format_profile: Dict = None) -> Dict[str, Any]:\n    \"\"\"\n    Main entry point.\n    Returns score 0.0-1.0 where 1.0 = clear, single, defensible thesis.\n    \"\"\"\n    # Split into paragraphs (blank line or double newline)\n    paragraphs = re.split(r'\\n\\s*\\n', text.strip())\n    paragraphs = [p.strip() for p in paragraphs if p.strip()]\n\n    if not paragraphs:\n        return {\n            \"dimension\": \"B1\",\n            \"dimension_name\": \"Thesis Clarity\",\n            \"score\": 0.0,\n            \"verdict\": \"fail\",\n            \"confidence\": 0.9,\n            \"evidence\": [{\"passage\": \"\", \"location\": \"document\", \"signal\": \"No text provided\", \"severity\": \"error\"}],\n            \"interpretation\": \"Empty text.\",\n            \"recommendation\": \"Provide content to evaluate.\"\n        }\n\n    # Extract claims from first and last paragraphs (most thesis-like positions)\n    first_claims = extract_claims_from_paragraph(paragraphs[0])\n    last_claims = extract_claims_from_paragraph(paragraphs[-1]) if len(paragraphs) > 1 else []\n\n    all_candidates = first_claims + last_claims\n\n    # Deduplicate (simple string match)\n    unique_candidates = []\n    for claim in all_candidates:\n        if claim not in unique_candidates:\n            unique_candidates.append(claim)\n\n    # Score based on number and quality of candidates\n    score = 1.0\n    issues = []\n\n    if len(unique_candidates) == 0:\n        score = 0.0\n        issues.append((\"no_thesis\", \"No clear thesis statement detected\"))\n    elif len(unique_candidates) == 1:\n        score = 0.9  # Good: single clear thesis\n        # Check if it's too vague\n        thesis = unique_candidates[0]\n        vague_indicators = ['it depends', 'maybe', 'perhaps', 'could be', 'might be', 'sometimes']\n        if any(vague in thesis.lower() for vague in vague_indicators):\n            score = 0.6\n            issues.append((\"vague_thesis\", f\"Thesis is vague: '{thesis[:50]}...'\"))\n    else:\n        score = 0.5  # Multiple competing theses\n        issues.append((\"multiple_theses\", f\"Found {len(unique_candidates)} potential theses: '{unique_candidates[0][:50]}...' and '{unique_candidates[1][:50]}...'\"))\n\n    # Additional check: does the thesis appear to be answered/resolved by the end?\n    if len(paragraphs) > 2 and len(unique_candidates) > 0:\n        thesis = unique_candidates[0]\n        # Simple check: does conclusion paragraph contain words from thesis?\n        conclusion = paragraphs[-1].lower()\n        thesis_words = set(re.findall(r'\\b\\w{4,}\\b', thesis.lower()))  # Words 4+ chars\n        conclusion_words = set(re.findall(r'\\b\\w{4,}\\b', conclusion))\n        overlap = len(thesis_words & conclusion_words)\n        if overlap < 2:  # Low word overlap suggests thesis not addressed\n            score = min(score, 0.7)\n            issues.append((\"thesis_not_resolved\", \"Thesis may not be resolved or addressed by conclusion\"))\n\n    # Clamp score\n    score = max(0.0, min(1.0, score))\n\n    # Verdict\n    if score >= 0.8:\n        verdict = \"pass\"\n    elif score >= 0.5:\n        verdict = \"warning\"\n    else:\n        verdict = \"fail\"\n\n    confidence = 0.8  # Medium-high confidence in heuristic\n\n    # Evidence\n    evidence = []\n    if unique_candidates:\n        evidence.append({\n            \"passage\": unique_candidates[0][:200],\n            \"location\": \"first_or_last_paragraph\",\n            \"signal\": f\"Primary thesis candidate: '{unique_candidates[0][:100]}...'\",\n            \"severity\": \"info\"\n        })\n        if len(unique_candidates) > 1:\n            evidence.append({\n                \"passage\": unique_candidates[1][:200],\n                \"location\": \"first_or_last_paragraph\",\n                \"signal\": f\"Secondary thesis candidate: '{unique_candidates[1][:100]}...'\",\n                \"severity\": \"warning\"\n            })\n    else:\n        evidence.append({\n            \"passage\": paragraphs[0][:200] if paragraphs else \"\",\n            \"location\": \"first_paragraph\",\n            \"signal\": \"No thesis-like sentence detected in opening\",\n            \"severity\": \"warning\"\n        })\n\n    # Interpretation and recommendation\n    if verdict == \"pass\":\n        interpretation = \"Clear, single thesis detected.\"\n        recommendation = \"Thesis is strong and clear.\"\n    elif verdict == \"warning\":\n        if len(unique_candidates) == 1:\n            interpretation = \"Thesis present but may need sharpening or resolve.\"\n            recommendation = \"Ensure thesis is specific, defensible, and addressed throughout.\"\n        else:\n            interpretation = \"Multiple competing theses detected.\"\n            recommendation = \"Choose one central claim and ensure all content supports it.\"\n    else:\n        interpretation = \"No clear thesis detected.\"\n        recommendation = \"State your central claim clearly in the opening paragraph.\"\n\n    return {\n        \"dimension\": \"B1\",\n        \"dimension_name\": \"Thesis Clarity\",\n        \"score\": round(score, 3),\n        \"verdict\": verdict,\n        \"confidence\": confidence,\n        \"evidence\": evidence,\n        \"interpretation\": interpretation,\n        \"recommendation\": recommendation\n    }\n\nif __name__ == \"__main__\":\n    if len(sys.argv) > 1:\n        text = \" \".join(sys.argv[1:])\n    else:\n        text = sys.stdin.read().strip()\n    # Load LinkedIn profile for testing\n    import os\n    import json as json_mod\n    profile_path = os.path.join(os.path.dirname(__file__), \"..\", \"config\", \"format_profiles\", \"linkedin.json\")\n    try:\n        with open(profile_path, 'r') as f:\n            profile = json_mod.load(f)\n    except:\n        profile = None\n    result = analyze(text, format_hint=\"linkedin\", format_profile=profile)\n    print(json.dumps(result, indent=2))"}],"isError":false,"timestamp":1775598440958}}
{"type":"message","id":"4052262a","parentId":"7c5dfb39","timestamp":"2026-04-07T21:47:27.854Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"ollama_call_efd6a0c1-357e-4067-8b60-98487ab7a4b8","name":"read","arguments":{"path":"/home/tiny4lurv/.openclaw/workspace/tinyqe/analyzers/proportionality.py"}}],"stopReason":"toolUse","api":"ollama","provider":"ollama","model":"minimax-m2.7:cloud","usage":{"input":60470,"output":158,"cacheRead":0,"cacheWrite":0,"totalTokens":60628,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"timestamp":1775598447853}}
{"type":"message","id":"8550fe14","parentId":"4052262a","timestamp":"2026-04-07T21:47:27.931Z","message":{"role":"toolResult","toolCallId":"ollama_call_efd6a0c1-357e-4067-8b60-98487ab7a4b8","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nProportionality Analyzer (C3)\nEvaluates whether evidence is proportionate to claims:\n- Extraordinary claims require extraordinary evidence\n- Simple claims don't need extensive evidence\n- Evidence length vs claim strength balance\n\"\"\"\nimport re\nimport json\nimport sys\nfrom typing import Dict, Any, List, Tuple\n\n# Indicators of extraordinary/strong claims\nEXTRAORDINARY_CLAIM_INDICATORS = [\n    r'\\bwill\\b.*\\brevolutionize\\b', r'\\bwill\\b.*\\btransform\\b', r'\\bwill\\b.*\\bchange everything\\b',\n    r'\\bnever\\b.*\\bbefore\\b', r'\\balways\\b', r'\\bnever\\b', r'\\bguaranteed\\b', r'\\b100%\\b', r'\\bperfect\\b',\n    r'\\bbest\\b.*\\bin\\b.*\\bthe\\b.*\\bworld\\b', r'\\bworst\\b.*\\bin\\b.*\\bthe\\b.*\\bworld\\b',\n    r'\\bbreakthrough\\b', r'\\bgame.changer\\b', r'\\bparadigm\\s+shift\\b', r'\\bmiracle\\b', r'\\bcure\\b',\n    r'\\beliminate\\b.*\\bproblem\\b', r'\\bsolve\\b.*\\bforever\\b', r'\\bend\\b.*\\b\\w+\\s+once\\s+and\\s+for\\s+all\\b',\n    r'\\bthe\\s+only\\b\\s+way\\b', r'\\bno\\s+more\\b', r'\\bnever\\s+again\\b', r'\\bthis\\s+will\\s+change\\b.*\\bforever\\b',\n    r'\\binstantly\\b', r'\\bimmediately\\b', r'\\bwithin\\s+24\\s+hours\\b', r'\\bresults\\s+guaranteed\\b'\n]\n\n# Indicators of moderate claims\nMODERATE_CLAIM_INDICATORS = [\n    r'\\bcan\\b.*\\bhelp\\b', r'\\bmay\\b.*\\bimprove\\b', r'\\btends\\s+to\\b', r'\\boften\\b.*\\bleads\\s+to\\b',\n    r'\\busually\\b', r'\\bgenerally\\b', r'\\bfrequently\\b', r'\\bcommonly\\b', r'\\btypically\\b',\n    r'\\bimproves\\b.*\\bby\\b', r'\\bincreases\\b.*\\bby\\b', r'\\bdecreases\\b.*\\bby\\b', r'\\breduces\\b.*\\bby\\b',\n    r'\\bsignificant\\b.*\\bimprovement\\b', r'\\bnoticeable\\b.*\\bchange\\b', r'\\bsubstantial\\b.*\\benefit\\b',\n    r'\\bbetter\\s+than\\b', r'\\bmore\\s+effective\\b\\s+than\\b'\n]\n\n# Indicators of weak/conservative claims\nWEAK_CLAIM_INDICATORS = [\n    r'\\bmight\\b', r'\\bcould\\b', r'\\bpossible\\b', r'\\bpossibly\\b', r'\\bperhaps\\b', r'\\bmaybe\\b',\n    r'\\bsuggests\\b', r'\\bindicates\\b', r'\\bappears\\b', r'\\bseems\\b', r'\\blikely\\b', r'\\bprobably\\b',\n    r'\\bassociated\\s+with\\b', r'\\blinked\\s+to\\b', r'\\bcorrelated\\s+with\\b', r'\\brelated\\s+to\\b',\n    r'\\bmay\\s+contribute\\b', r'\\bcould\\s+play\\s+a\\s+role\\b', r'\\bone\\s+factor\\s+is\\b', r'\\baspect\\s+of\\b'\n]\n\n# Evidence strength indicators\nSTRONG_EVIDENCE_INDICATORS = [\n    r'randomized\\s+controlled\\s+trial', r'\\brct\\b', r'\\bmeta\\-analysis\\b', r'\\bsystematic\\s+review\\b',\n    r'\\bdouble\\-blind\\b', r'\\blongitudinal\\s+study\\b', r'\\bcohort\\s+study\\b', r'\\bcase\\-control\\s+study\\b',\n    r'\\bp\\s+\\<\\s+0\\.001\\b', r'\\bp\\s+\\<\\s+0\\.01\\b', r'\\bconfidence\\s+interval\\b', r'\\bn\\s+=\\s+\\d{3,}\\b',\n    r'\\bsample\\s+size\\b.*\\d{3,}\\b', r'\\bmulticenter\\b', r'\\bpeer\\-reviewed\\b', r'\\bjournal\\b',\n    r'\\bstudy\\s+of\\b.*\\b\\d{3,}\\b\\s+participants\\b', r'\\bfollow\\-up\\b.*\\b\\d+\\s+(years?|months?)\\b'\n]\n\nMODERATE_EVIDENCE_INDICATORS = [\n    r'\\bp\\s+\\<\\s+0\\.05\\b', r'\\bn\\s+=\\s+\\d{2,}\\b', r'\\bsample\\s+size\\b.*\\d{2,}\\b', r'\\bpreliminary\\s+study\\b',\n    r'\\bpilot\\s+study\\b', r'\\bobservational\\s+study\\b', r'\\bcorrelational\\s+study\\b', r'\\bsurvey\\b',\n    r'\\bquestionnaire\\b', r'\\binterview\\b', r'\\bfocus\\s+group\\b', r'\\bcase\\s+report\\b', r'\\bcase\\s+series\\b',\n    r'\\bretrospective\\s+analysis\\b', r'\\bprospective\\s+analysis\\b', r'\\bchart\\s+review\\b'\n]\n\nWEAK_EVIDENCE_INDICATORS = [\n    r'\\banecdotal\\b', r'\\bcase\\s+example\\b', r'\\btestimonial\\b', r'\\bopinion\\b', r'\\bbelief\\b',\n    r'\\bthink\\b', r'\\bfeel\\b', r'\\bi\\s+believe\\b', r'\\bi\\s+think\\b', r'\\bmy\\s+experience\\b',\n    r'\\bone\\s+time\\b', r'\\bonce\\b', r'\\bin\\s+my\\s+practice\\b', r'\\bin\\s+my\\s+clinic\\b', r'\\bhearsay\\b',\n    r'\\bword\\s+of\\s+mouth\\b', r'\\brumor\\b', r'\\bspeculation\\b', r'\\bconjecture\\b', r'\\bguess\\b',\n    r'\\bpossibly\\b', r'\\bperhaps\\b', r'\\bmight\\b', r'\\bcould\\b', r'\\bsuggests\\b', r'\\bindicates\\b'\n]\n\ndef analyze(text: str, format_hint: str = \"generic\", format_profile: Dict = None) -> Dict[str, Any]:\n    \"\"\"\n    Main entry point.\n    Returns score 0.0-1.0 where 1.0 = excellent proportionality.\n    \"\"\"\n    if not text.strip():\n        return {\n            \"dimension\": \"C3\",\n            \"dimension_name\": \"Proportionality\",\n            \"score\": 0.0,\n            \"verdict\": \"fail\",\n            \"confidence\": 0.9,\n            \"evidence\": [{\"passage\": \"\", \"location\": \"document\", \"signal\": \"No text provided\", \"severity\": \"error\"}],\n            \"interpretation\": \"Empty text.\",\n            \"recommendation\": \"Provide content to evaluate.\"\n        }\n\n    text_lower = text.lower()\n    \n    # 1. Assess claim strength\n    extraordinary_score = sum(1 for pattern in EXTRAORDINARY_CLAIM_INDICATORS if re.search(pattern, text_lower))\n    moderate_score = sum(1 for pattern in MODERATE_CLAIM_INDICATORS if re.search(pattern, text_lower))\n    weak_score = sum(1 for pattern in WEAK_CLAIM_INDICATORS if re.search(pattern, text_lower))\n    \n    # Determine claim strength category\n    if extraordinary_score > 0:\n        claim_strength = \"extraordinary\"\n        claim_weight = 3.0\n    elif moderate_score > 0:\n        claim_strength = \"moderate\"\n        claim_weight = 2.0\n    elif weak_score > 0:\n        claim_strength = \"weak\"\n        claim_weight = 1.0\n    else:\n        # Default to moderate if no indicators found\n        claim_strength = \"moderate\"\n        claim_weight = 2.0\n    \n    # 2. Assess evidence strength\n    strong_evidence = sum(1 for pattern in STRONG_EVIDENCE_INDICATORS if re.search(pattern, text_lower))\n    moderate_evidence = sum(1 for pattern in MODERATE_EVIDENCE_INDICATORS if re.search(pattern, text_lower))\n    weak_evidence = sum(1 for pattern in WEAK_EVIDENCE_INDICATORS if re.search(pattern, text_lower))\n    \n    # Determine evidence strength category\n    if strong_evidence > 0:\n        evidence_strength = \"strong\"\n        evidence_weight = 3.0\n    elif moderate_evidence > 0:\n        evidence_strength = \"moderate\"\n        evidence_weight = 2.0\n    elif weak_evidence > 0:\n        evidence_strength = \"weak\"\n        evidence_weight = 1.0\n    else:\n        evidence_strength = \"none\"\n        evidence_weight = 0.0\n    \n    # 3. Calculate proportionality score\n    # Ideal: evidence_weight should match claim_weight\n    # Score = 1.0 - |evidence_weight - claim_weight| / max_weight\n    max_weight = 3.0\n    weight_diff = abs(evidence_weight - claim_weight)\n    proportionality_ratio = 1.0 - (weight_diff / max_weight)\n    score = max(0.0, proportionality_ratio)\n    score = round(score, 3)\n    \n    # 4. Verdict\n    if score >= 0.8:\n        verdict = \"pass\"\n    elif score >= 0.5:\n        verdict = \"warning\"\n    else:\n        verdict = \"fail\"\n    \n    confidence = 0.7  # Medium confidence in heuristic claim/evidence strength detection\n    \n    # Evidence for output\n    evidence_list = []\n    \n    # Claim strength evidence\n    claim_indicators_found = []\n    if extraordinary_score > 0:\n        claim_indicators_found.append(\"extraordinary\")\n    if moderate_score > 0:\n        claim_indicators_found.append(\"moderate\")\n    if weak_score > 0:\n        claim_indicators_found.append(\"weak\")\n    \n    if claim_indicators_found:\n        evidence_list.append({\n            \"passage\": f\"Claim strength assessed as: {', '.join(claim_indicators_found)}\",\n            \"location\": \"document\",\n            \"signal\": f\"Claim strength: {claim_strength}\",\n            \"severity\": \"info\"\n        })\n    else:\n        evidence_list.append({\n            \"passage\": \"No clear claim strength indicators detected\",\n            \"location\": \"document\",\n            \"signal\": \"Claim strength: unclear\",\n            \"severity\": \"warning\"\n        })\n    \n    # Evidence strength evidence\n    evidence_indicators_found = []\n    if strong_evidence > 0:\n        evidence_indicators_found.append(\"strong\")\n    if moderate_evidence > 0:\n        evidence_indicators_found.append(\"moderate\")\n    if weak_evidence > 0:\n        evidence_indicators_found.append(\"weak\")\n    \n    if evidence_indicators_found:\n        evidence_list.append({\n            \"passage\": f\"Evidence strength assessed as: {', '.join(evidence_indicators_found)}\",\n            \"location\": \"document\",\n            \"signal\": f\"Evidence strength: {evidence_strength}\",\n            \"severity\": \"info\"\n        })\n    else:\n        evidence_list.append({\n            \"passage\": \"No clear evidence strength indicators detected\",\n            \"location\": \"document\",\n            \"signal\": \"Evidence strength: none/weak\",\n            \"severity\": \"warning\" if evidence_weight == 0 else \"info\"\n        })\n    \n    # 5. Interpretation and recommendation\n    if verdict == \"pass\":\n        interpretation = f\"Evidence strength ({evidence_strength}) is proportionate to claim strength ({claim_strength}).\"\n        recommendation = \"Evidence proportionality is appropriate.\"\n    elif verdict == \"warning\":\n        if evidence_weight > claim_weight:\n            interpretation = f\"Evidence may be stronger than needed for the claims made.\"\n            recommendation = \"Consider whether the evidence presented exceeds what's needed to support the claims.\"\n        else:\n            interpretation = f\"Evidence may be insufficient for the strength of claims made.\"\n            recommendation = \"Consider strengthening evidence or tempering claims to achieve better proportionality.\"\n    else:\n        if evidence_weight == 0 and claim_weight > 0:\n            interpretation = \"Claims made without supporting evidence.\"\n            recommendation = \"All claims require some level of evidence. Add data, examples, or reasoning to support your points.\"\n        elif evidence_weight > claim_weight:\n            interpretation = f\"Evidence strength ({evidence_strength}) vastly exceeds claim strength ({claim_strength}).\"\n            recommendation = \"Consider whether extensive evidence is needed for these claims, or strengthen the claims to match the evidence.\"\n        else:\n            interpretation = f\"Evidence strength ({evidence_strength}) is insufficient for claim strength ({claim_strength}).\"\n            recommendation = \"Strengthen evidence with data, studies, or examples, or temper claims to match available evidence.\"\n    \n    return {\n        \"dimension\": \"C3\",\n        \"dimension_name\": \"Proportionality\",\n        \"score\": score,\n        \"verdict\": verdict,\n        \"confidence\": confidence,\n        \"evidence\": evidence_list,\n        \"interpretation\": interpretation,\n        \"recommendation\": recommendation\n    }\n\nif __name__ == \"__main__\":\n    if len(sys.argv) > 1:\n        text = \" \".join(sys.argv[1:])\n    else:\n        text = sys.stdin.read().strip()\n    result = analyze(text)\n    print(json.dumps(result, indent=2))"}],"isError":false,"timestamp":1775598447901}}
{"type":"message","id":"710e605d","parentId":"8550fe14","timestamp":"2026-04-07T21:47:33.055Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"ollama_call_39971080-f285-435a-8342-9ab7447a1fbd","name":"read","arguments":{"path":"/home/tiny4lurv/.openclaw/workspace/tinyqe/analyzers/structural_completeness.py"}}],"stopReason":"toolUse","api":"ollama","provider":"ollama","model":"minimax-m2.7:cloud","usage":{"input":63452,"output":78,"cacheRead":0,"cacheWrite":0,"totalTokens":63530,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"timestamp":1775598453054}}
{"type":"message","id":"845dd288","parentId":"710e605d","timestamp":"2026-04-07T21:47:33.116Z","message":{"role":"toolResult","toolCallId":"ollama_call_39971080-f285-435a-8342-9ab7447a1fbd","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nStructural Completeness Analyzer (B3)\nChecks whether the argument has all necessary components: \nclaim → setup → evidence → complication → resolution (or hook → development → landing for short-form).\n\"\"\"\nimport re\nimport json\nimport sys\nfrom typing import Dict, Any, List\n\ndef analyze(text: str, format_hint: str = \"generic\", format_profile: Dict = None) -> Dict[str, Any]:\n    \"\"\"\n    Main entry point.\n    For LinkedIn/X: looks for hook → development → landing.\n    For blog/essay: looks for claim → setup → evidence → complication → resolution.\n    Returns score 0.0-1.0 where 1.0 = structurally complete.\n    \"\"\"\n    if not text.strip():\n        return {\n            \"dimension\": \"B3\",\n            \"dimension_name\": \"Structural Completeness\",\n            \"score\": 0.0,\n            \"verdict\": \"fail\",\n            \"confidence\": 0.9,\n            \"evidence\": [{\"passage\": \"\", \"location\": \"document\", \"signal\": \"No text provided\", \"severity\": \"error\"}],\n            \"interpretation\": \"Empty text.\",\n            \"recommendation\": \"Provide content to evaluate.\"\n        }\n\n    # Detect format for structural expectations\n    try:\n        # When run from tinyqe.py\n        from core.format_detector import detect_format, load_format_profile\n    except ImportError:\n        # When run standalone\n        import sys\n        import os\n        sys.path.insert(0, os.path.join(os.path.dirname(__file__), \"..\", \"core\"))\n        from format_detector import detect_format, load_format_profile\n    fmt, _ = detect_format(text)\n    profile = load_format_profile(fmt) if format_profile is None else format_profile\n\n    # Initialize component flags\n    found = {\n        \"hook\": False,\n        \"claim\": False,\n        \"setup\": False,\n        \"evidence\": False,\n        \"complication\": False,\n        \"resolution\": False,\n        \"development\": False,\n        \"landing\": False\n    }\n\n    evidence = []\n\n    # Split into paragraphs\n    paragraphs = re.split(r'\\n\\s*\\n', text.strip())\n    paragraphs = [p.strip() for p in paragraphs if p.strip()]\n\n    if not paragraphs:\n        return {\n            \"dimension\": \"B3\",\n            \"dimension_name\": \"Structural Completeness\",\n            \"score\": 0.0,\n            \"verdict\": \"fail\",\n            \"confidence\": 0.9,\n            \"evidence\": [{\"passage\": \"\", \"location\": \"document\", \"signal\": \"No paragraphs found\", \"severity\": \"error\"}],\n            \"interpretation\": \"No discernible structure.\",\n            \"recommendation\": \"Organize content into paragraphs with clear intent.\"\n        }\n\n    # Short-form (LinkedIn, X, copy): expect hook → development → landing\n    if fmt in [\"linkedin\", \"x_thread\", \"copywriting\"]:\n        # Hook: first paragraph grabs attention (question, surprising stat, bold claim)\n        first = paragraphs[0].lower()\n        hook_indicators = [\n            r'what if', r'how to', r'why', r'secret', r'the truth', r'you re', r'your',\n            r'\\d+%', r'study shows', r'research finds', r'breakthrough', r'warning',\n            r'stop', r'avoid', r'never', r'always', r'best', r'worst', r'how to'\n        ]\n        if any(re.search(pattern, first) for pattern in hook_indicators) or first.strip().endswith('?'):\n            found[\"hook\"] = True\n            evidence.append({\"passage\": paragraphs[0][:100], \"location\": \"paragraph 1\", \"signal\": \"Hook detected\", \"severity\": \"info\"})\n\n        # Development: middle paragraphs elaborate, provide examples, build argument\n        if len(paragraphs) >= 2:\n            # Simple heuristic: if we have multiple paragraphs, assume development\n            found[\"development\"] = True\n            evidence.append({\"passage\": f\"{len(paragraphs)-2} middle paragraphs\", \"location\": \"paragraphs 2-{len(paragraphs)-1}\", \"signal\": \"Development present\", \"severity\": \"info\"})\n\n        # Landing: last paragraph resolves, provides CTA, or returns to hook\n        last = paragraphs[-1].lower()\n        landing_indicators = [\n            r'that s', r'this is', r'therefore', r'thus', r'in summary', r'to conclude',\n            r'remember', r'try', r'start', r'begin', r'take action', r'learn more',\n            r'sign up', r'get started', r'download', r'free', r'offer', r'save this'\n        ]\n        if any(re.search(pattern, last) for pattern in landing_indicators) or \\\n           last.strip().endswith('.') and len(paragraphs[-1].split()) > 5:\n            found[\"landing\"] = True\n            evidence.append({\"passage\": paragraphs[-1][:100], \"location\": f\"paragraph {len(paragraphs)}\", \"signal\": \"Landing detected\", \"severity\": \"info\"})\n\n        # Structural completeness for short-form: hook + development + landing\n        required = [\"hook\", \"development\", \"landing\"]\n        missing = [r for r in required if not found[r]]\n\n    else:\n        # Long-form (blog, essay, academic): expect claim → setup → evidence → complication → resolution\n        # Claim: clear thesis statement (we reuse thesis clarity logic or approximate)\n        # Look for declarative statement in first or second paragraph\n        claim_patterns = [\n            r'\\bis\\b', r'\\bare\\b', r'\\bwill\\b', r'\\bmust\\b', r'\\bshould\\b', r'\\bcauses\\b', r'\\bleads to\\b',\n            r'\\bshows that\\b', r'\\bdemonstrates that\\b', r'\\bevidence suggests\\b', r'\\bstudy indicates\\b'\n        ]\n        full_text = ' '.join(paragraphs[:2]).lower()\n        if any(re.search(pattern, full_text) for pattern in claim_patterns):\n            found[\"claim\"] = True\n            # Find the sentence\n            for para in paragraphs[:2]:\n                for sent in re.split(r'[.!?]+', para):\n                    if any(re.search(pattern, sent.lower()) for pattern in claim_patterns):\n                        evidence.append({\"passage\": sent.strip()[:100], \"location\": \"early paragraphs\", \"signal\": \"Claim detected\", \"severity\": \"info\"})\n                        break\n                if found[\"claim\"]:\n                    break\n\n        # Setup: background, context, problem statement\n        setup_indicators = [\n            r'background', r'context', r'problem', r'challenge', r'issue', r'situation',\n            r'currently', r'today', r'in recent years', r'according to', r'data shows'\n        ]\n        setup_text = ' '.join(paragraphs).lower()\n        if any(re.search(pattern, setup_text) for pattern in setup_indicators):\n            found[\"setup\"] = True\n            evidence.append({\"passage\": \"Context or background detected\", \"location\": \"document\", \"signal\": \"Setup detected\", \"severity\": \"info\"})\n\n        # Evidence: data, examples, citations, quotes\n        evidence_indicators = [\n            r'\\d+%', r'\\d+\\.\\d+', r'according to', r'study', r'research', r'data shows',\n            r'p \\<', r'correlation', r'example', r'for instance', r'case study',\n            r'citation', r'reference', r'\\bdoi\\b', r'http', r'www\\.'\n        ]\n        evidence_text = ' '.join(paragraphs).lower()\n        if any(re.search(pattern, evidence_text) for pattern in evidence_indicators):\n            found[\"evidence\"] = True\n            evidence.append({\"passage\": \"Data, examples, or citations detected\", \"location\": \"document\", \"signal\": \"Evidence detected\", \"severity\": \"info\"})\n\n        # Complication: counterargument, obstacle, twist, limitation\n        complication_indicators = [\n            r'however', r'but', r'although', r'despite', r'yet', r'still', r'nevertheless',\n            r'despite this', r'on the other hand', r'limitations', r'challenges remain',\n            r'obstacles', r'drawbacks', r'trade-off', r'cost', r'risk', r'concern'\n        ]\n        complication_text = ' '.join(paragraphs).lower()\n        if any(re.search(pattern, complication_text) for pattern in complication_indicators):\n            found[\"complication\"] = True\n            evidence.append({\"passage\": \"Counterargument or complication detected\", \"location\": \"document\", \"signal\": \"Complication detected\", \"severity\": \"info\"})\n\n        # Resolution: solution, recommendation, conclusion, call to action\n        resolution_indicators = [\n            r'therefore', r'thus', r'hence', r'as a result', r'in conclusion', r'to summarize',\n            r'we recommend', r'solution', r'resolve', r'address', r'overcome', r'mitigate',\n            r'future work', r'next steps', r'call to action'\n        ]\n        resolution_text = ' '.join(paragraphs).lower()\n        if any(re.search(pattern, resolution_text) for pattern in resolution_indicators):\n            found[\"resolution\"] = True\n            evidence.append({\"passage\": \"Resolution or conclusion detected\", \"location\": \"document\", \"signal\": \"Resolution detected\", \"severity\": \"info\"})\n\n        # Structural completeness for long-form: need at least claim + evidence + resolution\n        required = [\"claim\", \"evidence\", \"resolution\"]\n        missing = [r for r in required if not found[r]]\n\n    # Calculate score: proportion of required components found\n    total_required = len(required)\n    found_required = sum(1 for r in required if found[r])\n    score = found_required / total_required if total_required > 0 else 0.0\n    score = round(score, 3)\n\n    # Verdict\n    if score >= 0.8:\n        verdict = \"pass\"\n    elif score >= 0.5:\n        verdict = \"warning\"\n    else:\n        verdict = \"fail\"\n\n    confidence = 0.75  # Medium confidence in heuristic structure detection\n\n    # If no evidence collected, add a generic one\n    if not evidence:\n        evidence.append({\n            \"passage\": text[:100],\n            \"location\": \"document\",\n            \"signal\": \"No structural components clearly detected\",\n            \"severity\": \"warning\"\n        })\n\n    # Interpretation and recommendation\n    if verdict == \"pass\":\n        interpretation = f\"Structure appears complete: {', '.join([r.upper() for r in required if found[r]])} present.\"\n        recommendation = \"Structure is sound.\"\n    elif verdict == \"warning\":\n        interpretation = f\"Missing structural components: {', '.join([m.upper() for m in missing])}.\"\n        if fmt in [\"linkedin\", \"x_thread\", \"copywriting\"]:\n            recommendation = \"Ensure your post has a hook (attention-grabber), development (elaboration), and landing (resolution/CTA).\"\n        else:\n            recommendation = \"Ensure your argument includes a clear claim, supporting evidence, and a resolution or conclusion.\"\n    else:\n        interpretation = f\"Structure is incomplete. Missing: {', '.join([m.upper() for m in missing])}.\"\n        if fmt in [\"linkedin\", \"x_thread\", \"copywriting\"]:\n            recommendation = \"Add a clear hook, develop your point in middle paragraphs, and end with a landing (summary, CTA, or return to hook).\"\n        else:\n            recommendation = \"Restructure to include: claim → setup → evidence → complication → resolution.\"\n\n    return {\n        \"dimension\": \"B3\",\n        \"dimension_name\": \"Structural Completeness\",\n        \"score\": score,\n        \"verdict\": verdict,\n        \"confidence\": confidence,\n        \"evidence\": evidence,\n        \"interpretation\": interpretation,\n        \"recommendation\": recommendation\n    }\n\nif __name__ == \"__main__\":\n    if len(sys.argv) > 1:\n        text = \" \".join(sys.argv[1:])\n    else:\n        text = sys.stdin.read().strip()\n    result = analyze(text)\n    print(json.dumps(result, indent=2))"}],"isError":false,"timestamp":1775598453094}}
